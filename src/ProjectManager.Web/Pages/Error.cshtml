@page
@model ErrorModel
@{
    ViewData["Title"] = "系統錯誤";
}

<h1 class="text-danger">系統錯誤</h1>
<h2 class="text-danger">處理請求時發生錯誤。</h2>

@if (Model.ShowRequestId)
{
    <p>
        <strong>請求編號：</strong> <code>@Model.RequestId</code>
    </p>
}

<h3>開發環境提示</h3>
<p>
    開發環境會顯示更詳細的錯誤資訊，方便本機除錯。
</p>
<p>
    正式內網部署時請使用生產環境設定，避免向使用者顯示敏感異常內容。
</p>
