@page
@model ErrorModel
@{
    ViewData["Title"] = "系统错误";
}

<h1 class="text-danger">系统错误</h1>
<h2 class="text-danger">处理请求时发生错误。</h2>

@if (Model.ShowRequestId)
{
    <p>
        <strong>请求编号：</strong> <code>@Model.RequestId</code>
    </p>
}

<h3>开发环境提示</h3>
<p>
    开发环境会显示更详细的错误信息，方便本机调试。
</p>
<p>
    正式内网部署时请使用生产环境配置，避免向用户显示敏感异常内容。
</p>
