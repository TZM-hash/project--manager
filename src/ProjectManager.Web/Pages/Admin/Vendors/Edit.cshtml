@page
@model ProjectManager.Web.Pages.Admin.Vendors.EditModel
@{
    ViewData["Title"] = "編輯廠商";
}

<div class="page-header">
    <div>
        <h1 class="page-title">編輯廠商</h1>
        <div class="page-subtitle">修改廠商公司和對接人員資訊</div>
    </div>
    <div class="page-actions">
        <a class="btn btn-outline-secondary" asp-page="./Index">返回列表</a>
    </div>
</div>

<form method="post" class="mt-3">
    <input asp-for="Input.Id" type="hidden" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <section class="form-section">
        <h2 class="form-section-title">公司資訊</h2>
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label">公司名稱 <span class="text-danger">*</span></label>
                <input class="form-control" asp-for="Input.CompanyName" />
                <span class="text-danger" asp-validation-for="Input.CompanyName"></span>
            </div>
            <div class="col-md-6">
                <label class="form-label">備註</label>
                <input class="form-control" asp-for="Input.Notes" />
            </div>
        </div>
    </section>

    <section class="form-section">
        <h2 class="form-section-title">聯絡人資訊</h2>
        <div class="data-table-wrap">
            <table class="table table-sm align-middle data-table">
                <thead>
                    <tr>
                        <th>姓名</th>
                        <th>電話</th>
                        <th>備註</th>
                        <th>刪除</th>
                        <th>操作</th>
                    </tr>
                </thead>
                <tbody>
                    @for (var i = 0; i < Model.Input.Contacts.Count; i++)
                    {
                        <tr>
                            <input asp-for="Input.Contacts[i].Id" type="hidden" />
                            <td><input class="form-control form-control-sm" asp-for="Input.Contacts[i].Name" /></td>
                            <td><input class="form-control form-control-sm" asp-for="Input.Contacts[i].Phone" /></td>
                            <td><input class="form-control form-control-sm" asp-for="Input.Contacts[i].Notes" /></td>
                            <td>
                                @if (Model.Input.Contacts[i].Id > 0)
                                {
                                    <input class="form-check-input" asp-for="Input.Contacts[i].IsDeleted" />
                                }
                            </td>
                            <td>
                                @if (Model.Input.Contacts.Count > 1)
                                {
                                    <button type="button" class="btn btn-sm btn-outline-danger" onclick="removeContactRow(this)">刪除行</button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <button type="button" class="btn btn-sm btn-outline-secondary mt-2" onclick="addContactRow()">添加聯絡人</button>
    </section>

    <div class="mt-4">
        <button type="submit" class="btn btn-primary">儲存</button>
        <a class="btn btn-outline-secondary" asp-page="./Index">返回</a>
    </div>
</form>

<script>
    function addContactRow() {
        var tableBody = document.querySelector('table tbody');
        var rowCount = tableBody.querySelectorAll('tr').length;
        var template = `
            <tr>
                <input name="Input.Contacts[${rowCount}].Id" type="hidden" value="0" />
                <input name="Input.Contacts[${rowCount}].IsDeleted" type="hidden" value="false" />
                <td><input class="form-control form-control-sm" name="Input.Contacts[${rowCount}].Name" /></td>
                <td><input class="form-control form-control-sm" name="Input.Contacts[${rowCount}].Phone" /></td>
                <td><input class="form-control form-control-sm" name="Input.Contacts[${rowCount}].Notes" /></td>
                <td></td>
                <td>
                    <button type="button" class="btn btn-sm btn-outline-danger" onclick="removeContactRow(this)">刪除行</button>
                </td>
            </tr>
        `;
        tableBody.insertAdjacentHTML('beforeend', template);
    }

    function removeContactRow(button) {
        button.closest('tr').remove();
    }
</script>