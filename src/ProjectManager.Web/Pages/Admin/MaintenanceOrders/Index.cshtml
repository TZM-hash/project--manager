@page
@using ProjectManager.Web.Extensions
@model ProjectManager.Web.Pages.Admin.MaintenanceOrders.IndexModel
@{
    ViewData["Title"] = "保養訂單總覽";
}

<div class="page-header">
    <div>
        <h1 class="page-title">保養訂單總覽</h1>
        <div class="page-subtitle">統一管理維保合約、執行範圍、進度與保養內容</div>
    </div>
    <div class="page-actions">
        <a class="btn btn-primary" asp-page="./Create">新增</a>
    </div>
</div>

<div class="metric-grid dashboard-grid">
    @foreach (var metric in Model.Metrics)
    {
        <div class="metric-card metric-@metric.Accent">
            <div class="metric-label">@metric.Label</div>
            <div class="metric-value" data-countup>@metric.Value</div>
            <div class="metric-hint">@metric.Hint</div>
        </div>
    }
</div>

<div class="insight-grid">
    <section class="chart-card">
        <div class="chart-title">保養方式分布</div>
        <div class="chart-subtitle">現場、遠端或混合執行</div>
        <div class="bar-list">
            @foreach (var slice in Model.MethodSlices)
            {
                <div class="bar-row" style="--bar-width:@slice.Percent%;--bar-color:@slice.Color">
                    <div class="bar-row-label">@slice.Label</div>
                    <div class="bar-track"><span></span></div>
                    <div class="bar-value">@slice.Value.ToString("0")</div>
                </div>
            }
        </div>
    </section>
    <section class="chart-card">
        <div class="chart-title">保養進度分布</div>
        <div class="chart-subtitle">按目前維保進度分群組</div>
        <div class="bar-list">
            @foreach (var slice in Model.ProgressSlices)
            {
                <div class="bar-row" style="--bar-width:@slice.Percent%;--bar-color:@slice.Color">
                    <div class="bar-row-label">@slice.Label</div>
                    <div class="bar-track"><span></span></div>
                    <div class="bar-value">@slice.Value.ToString("0")</div>
                </div>
            }
        </div>
    </section>
</div>

<form method="get" class="filter-panel advanced-filter-panel" data-filter-drawer data-saved-view-filters>
    <div class="filter-quick-row">
        <div class="filter-quick-main">
            <input class="form-control" asp-for="CustomerName" placeholder="搜尋客戶名稱" />
            <input class="form-control" asp-for="Year" placeholder="年度" />
        </div>
        <div class="filter-quick-actions">
            <button class="btn btn-outline-secondary" type="button" data-filter-drawer-toggle>進階篩選</button>
            <button class="btn btn-primary" type="submit">查詢</button>
        </div>
    </div>
    <div class="filter-drawer" data-filter-drawer-panel>
        <div class="filter-drawer-header">
            <div>
                <div class="filter-drawer-title">進階篩選</div>
                <div class="filter-drawer-subtitle">依保養方式、執行人和保養進度篩選訂單</div>
            </div>
            <button class="btn btn-sm btn-outline-secondary" type="button" data-filter-drawer-close>收起</button>
        </div>
        <div class="row g-2">
            <div class="col-md-3">
                <select class="form-select" asp-for="Method" asp-items="Model.MethodOptions">
                    <option value="">保養方式</option>
                </select>
            </div>
            <div class="col-md-3">
                <select class="form-select" asp-for="ExecutorUserId" asp-items="Model.ExecutorOptions">
                    <option value="">保養執行人</option>
                </select>
            </div>
            <div class="col-md-3"><input class="form-control" asp-for="MinProgressPercent" placeholder="最小進度 %" /></div>
            <div class="col-md-3"><input class="form-control" asp-for="MaxProgressPercent" placeholder="最大進度 %" /></div>
        </div>
    </div>
    <input type="hidden" asp-for="PageSize" />
    <input type="hidden" name="PageNumber" value="1" />
</form>

<partial name="_FilterSummary" model="Model.FilterSummary" />
<partial name="_SavedDataViewBar" model="Model.SavedViewBar" />

<form method="post" asp-page-handler="BatchDelete" class="bulk-toolbar" data-bulk-form data-confirm-message="確定刪除選中的保養訂單嗎？">
    <div class="bulk-toolbar-copy">
        <span class="bulk-toolbar-count" data-selected-count>0</span>
        <span>個訂單已選擇</span>
    </div>
    <div class="bulk-toolbar-actions">
        <input type="hidden" asp-for="Year" />
        <input type="hidden" asp-for="CustomerName" />
        <input type="hidden" asp-for="Method" />
        <input type="hidden" asp-for="ExecutorUserId" />
        <input type="hidden" asp-for="MinProgressPercent" />
        <input type="hidden" asp-for="MaxProgressPercent" />
        <input type="hidden" asp-for="PageNumber" />
        <input type="hidden" asp-for="PageSize" />
        <button type="submit" class="btn btn-outline-danger" data-bulk-requires-selection data-processing-label="正在刪除…">批量刪除</button>
    </div>
</form>

<div class="data-list-card">
    <div class="maintenance-table-toolbar">
        <div class="maintenance-table-caption">
            <strong>維保合約明細</strong>
            <span>共 @Model.TotalCount 筆</span>
        </div>
        <div class="d-flex gap-2">
        <div class="dropdown" data-row-spacing>
            <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-row-spacing-toggle>行間距</button>
            <div class="dropdown-menu dropdown-menu-end p-2">
                <button type="button" class="dropdown-item" data-row-spacing-option="compact">緊湊</button>
                <button type="button" class="dropdown-item" data-row-spacing-option="normal">預設</button>
                <button type="button" class="dropdown-item" data-row-spacing-option="spacious">寬鬆</button>
            </div>
        </div>
        <div class="dropdown" data-column-manager>
            <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-column-manager-toggle>
                <svg class="nav-icon" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
                列管理
            </button>
            <div class="dropdown-menu dropdown-menu-end p-3 column-manager-menu">
                <div class="d-flex justify-content-between align-items-center mb-2 pb-2 border-bottom">
                    <strong>顯示欄位</strong>
                    <div>
                        <button type="button" class="btn btn-sm btn-link p-0 me-2" data-column-manager-all>全選</button>
                        <button type="button" class="btn btn-sm btn-link p-0" data-column-manager-none>全不選</button>
                    </div>
                </div>
                <div data-column-manager-list></div>
            </div>
        </div>
        </div>
    </div>
    <div class="data-table-wrap">
        <table id="maintenance-orders-table" class="table table-sm align-middle data-table maintenance-order-table"
               data-column-manager-table
               data-initial-visible-columns='@System.Text.Json.JsonSerializer.Serialize(Model.SavedViewBar.VisibleColumns)'
               data-initial-row-density="@Model.SavedViewBar.RowDensity">
        <thead>
            <tr class="maintenance-group-row">
                <th class="checkbox-cell" rowspan="2"><input class="form-check-input" type="checkbox" data-bulk-check-all aria-label="選擇全部保養訂單" /></th>
                <th rowspan="2" data-column="item" data-column-label="項次" data-column-order="1" data-column-fixed>項次</th>
                <th colspan="3" data-column-group="contractNumber customerName siteName">客戶與合約</th>
                <th rowspan="2" data-column="executor" data-column-label="經辦" data-column-order="5">經辦</th>
                <th colspan="2" data-column-group="contractStart contractEnd">維保合約時間</th>
                <th colspan="3" data-column-group="remoteScope softwareScope hardwareScope">維保範圍</th>
                <th rowspan="2" data-column="progress" data-column-label="進度" data-column-order="11">進度</th>
                <th rowspan="2" data-column="description" data-column-label="維保內容說明" data-column-order="12">維保內容說明</th>
                <th colspan="4" data-column-group="method onSiteCount remoteCount handover">補充資訊</th>
                <th colspan="2" data-column-group="updatedAt updatedBy">更新資訊</th>
                <th rowspan="2" data-column="actions" data-column-label="操作" data-column-fixed class="text-end maintenance-actions-column">操作</th>
            </tr>
            <tr class="maintenance-subheader-row">
                <th data-column="contractNumber" data-column-label="合約編號" data-column-order="2" data-column-fixed>合約編號</th>
                <th data-column="customerName" data-column-label="客戶名稱" data-column-order="3" data-column-fixed>客戶名稱</th>
                <th data-column="siteName" data-column-label="廠區／據點" data-column-order="4">廠區／據點</th>
                <th data-column="contractStart" data-column-label="開始日期" data-column-order="6">開始</th>
                <th data-column="contractEnd" data-column-label="結束日期" data-column-order="7">結束</th>
                <th data-column="remoteScope" data-column-label="遠端維保" data-column-order="8">遠端</th>
                <th data-column="softwareScope" data-column-label="現場軟體" data-column-order="9">現場軟體</th>
                <th data-column="hardwareScope" data-column-label="現場硬體" data-column-order="10">現場硬體</th>
                <th data-column="method" data-column-label="保養方式" data-column-order="13">方式</th>
                <th data-column="onSiteCount" data-column-label="現場次數" data-column-order="14">現場次數</th>
                <th data-column="remoteCount" data-column-label="遠端次數" data-column-order="15">遠端次數</th>
                <th data-column="handover" data-column-label="簽收移交" data-column-order="16">簽收移交</th>
                <th data-column="updatedAt" data-column-label="更新日期" data-column-order="17">更新日期</th>
                <th data-column="updatedBy" data-column-label="更新人員" data-column-order="18">更新人員</th>
            </tr>
        </thead>
        <tbody>
        @for (var index = 0; index < Model.Orders.Count; index++)
        {
            var order = Model.Orders[index];
            var itemNumber = ((Model.PageNumber - 1) * Model.PageSize) + index + 1;
            var hasRemoteScope = order.MaintenanceMethod is ProjectManager.Web.Models.MaintenanceMethod.Remote or ProjectManager.Web.Models.MaintenanceMethod.Both || order.RemoteAnnualCount > 0;
            <tr>
                <td class="checkbox-cell"><input class="form-check-input" type="checkbox" value="@order.Id" data-bulk-checkbox /></td>
                <td data-column="item" class="numeric">@itemNumber</td>
                <td data-column="contractNumber" class="text-nowrap"><strong>@order.ContractNumber</strong></td>
                <td data-column="customerName" class="maintenance-customer-cell"><strong>@order.CustomerName</strong><small>@order.Year 年保養案</small></td>
                <td data-column="siteName">@order.SiteName</td>
                <td data-column="executor">@(order.Executor?.DisplayName ?? order.Executor?.UserName ?? order.ExecutorUserId)</td>
                <td data-column="contractStart" class="text-nowrap">@order.MaintenanceStartDate.ToString("yyyy-MM-dd")</td>
                <td data-column="contractEnd" class="text-nowrap">@order.MaintenanceEndDate.ToString("yyyy-MM-dd")</td>
                <td data-column="remoteScope" class="maintenance-scope-check">@(hasRemoteScope ? "✓" : "—")</td>
                <td data-column="softwareScope">@order.OnSiteSoftwareFrequency</td>
                <td data-column="hardwareScope">@order.OnSiteHardwareFrequency</td>
                <td data-column="progress" class="numeric"><partial name="_PercentBar" model="new ProjectManager.Web.Pages.Shared.PercentBarModel(order.ProgressPercent, compact: false)" /></td>
                <td data-column="description" class="maintenance-description-cell"><span class="table-text-clamp" data-full-text="@order.MaintenanceDescription">@order.MaintenanceDescription</span></td>
                <td data-column="method">@order.MaintenanceMethod.GetDisplayName()</td>
                <td data-column="onSiteCount" class="numeric">@order.OnSiteAnnualCount</td>
                <td data-column="remoteCount" class="numeric">@order.RemoteAnnualCount</td>
                <td data-column="handover" class="numeric"><partial name="_PercentBar" model="new ProjectManager.Web.Pages.Shared.PercentBarModel(order.HandoverPercent)" /></td>
                <td data-column="updatedAt" class="text-nowrap">@order.UpdatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                <td data-column="updatedBy">@(order.UpdatedByUser?.DisplayName ?? order.UpdatedByUser?.UserName ?? order.UpdatedByUserId)</td>
                <td data-column="actions" class="text-end text-nowrap maintenance-actions-column">
                    <a class="btn btn-sm btn-outline-secondary" asp-page="./Edit" asp-route-id="@order.Id">編輯</a>
                    <form method="post" asp-page-handler="Delete" asp-route-id="@order.Id" asp-route-Year="@Model.Year" asp-route-CustomerName="@Model.CustomerName" asp-route-Method="@Model.Method" asp-route-ExecutorUserId="@Model.ExecutorUserId" asp-route-MinProgressPercent="@Model.MinProgressPercent" asp-route-MaxProgressPercent="@Model.MaxProgressPercent" asp-route-PageNumber="@Model.PageNumber" asp-route-PageSize="@Model.PageSize" class="d-inline" onsubmit="return confirm('確定刪除該訂單嗎？');">
                        <button type="submit" class="btn btn-sm btn-outline-danger">刪除</button>
                    </form>
                </td>
            </tr>
        }
        @if (!Model.Orders.Any())
        {
            <tr>
                <td colspan="20">
                    <partial name="_EmptyState" model='new ProjectManager.Web.Pages.Shared.EmptyStateViewModel(
                        "目前沒有保養訂單",
                        "可以新增第一筆保養訂單，或清除篩選後重新查看。",
                        "inbox",
                        "新增保養訂單",
                        "/Admin/MaintenanceOrders/Create",
                        ClearActionText: "清除篩選",
                        ClearActionPage: "/Admin/MaintenanceOrders/Index")' />
                </td>
            </tr>
        }
        </tbody>
        </table>
    </div>
    <partial name="_Pagination" model="Model.Pagination" />
</div>
