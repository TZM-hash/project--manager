@page
@using ProjectManager.Web.Extensions
@model ProjectManager.Web.Pages.Admin.MaintenanceOrders.IndexModel
@{
    ViewData["Title"] = "保養訂單管理";
}

<div class="page-header">
    <div>
        <h1 class="page-title">保養訂單管理</h1>
        <div class="page-subtitle">管理年度保養訂單，跟踪保養执行与签收移交進度</div>
    </div>
    <div class="page-actions">
        <a class="btn btn-primary" asp-page="./Create">新增</a>
    </div>
</div>

<div class="metric-grid dashboard-grid">
    @foreach (var metric in Model.Metrics)
    {
        <div class="metric-card metric-@metric.Accent">
            <div class="metric-label">@metric.Label</div>
            <div class="metric-value" data-countup>@metric.Value</div>
            <div class="metric-hint">@metric.Hint</div>
        </div>
    }
</div>

<div class="insight-grid">
    <section class="chart-card">
        <div class="chart-title">保養方式分布</div>
        <div class="chart-subtitle">现场、远程或混合执行</div>
        <div class="bar-list">
            @foreach (var slice in Model.MethodSlices)
            {
                <div class="bar-row" style="--bar-width:@slice.Percent%;--bar-color:@slice.Color">
                    <div class="bar-row-label">@slice.Label</div>
                    <div class="bar-track"><span></span></div>
                    <div class="bar-value">@slice.Value.ToString("0")</div>
                </div>
            }
        </div>
    </section>
    <section class="chart-card">
        <div class="chart-title">移交百分比分布</div>
        <div class="chart-subtitle">按移交進度分群組</div>
        <div class="bar-list">
            @foreach (var slice in Model.HandoverSlices)
            {
                <div class="bar-row" style="--bar-width:@slice.Percent%;--bar-color:@slice.Color">
                    <div class="bar-row-label">@slice.Label</div>
                    <div class="bar-track"><span></span></div>
                    <div class="bar-value">@slice.Value.ToString("0")</div>
                </div>
            }
        </div>
    </section>
</div>

<form method="get" class="filter-panel advanced-filter-panel" data-filter-drawer>
    <div class="filter-quick-row">
        <div class="filter-quick-main">
            <input class="form-control" asp-for="CustomerName" placeholder="搜尋客戶名稱" />
            <input class="form-control" asp-for="Year" placeholder="年度" />
        </div>
        <div class="filter-quick-actions">
            <button class="btn btn-outline-secondary" type="button" data-filter-drawer-toggle>進階篩選</button>
            <button class="btn btn-primary" type="submit">查詢</button>
        </div>
    </div>
    <div class="filter-drawer" data-filter-drawer-panel>
        <div class="filter-drawer-header">
            <div>
                <div class="filter-drawer-title">進階篩選</div>
                <div class="filter-drawer-subtitle">按保養方式、执行人和移交百分比篩選訂單</div>
            </div>
            <button class="btn btn-sm btn-outline-secondary" type="button" data-filter-drawer-close>收起</button>
        </div>
        <div class="row g-2">
            <div class="col-md-3">
                <select class="form-select" asp-for="Method" asp-items="Model.MethodOptions">
                    <option value="">保養方式</option>
                </select>
            </div>
            <div class="col-md-3">
                <select class="form-select" asp-for="ExecutorUserId" asp-items="Model.ExecutorOptions">
                    <option value="">保養执行人</option>
                </select>
            </div>
            <div class="col-md-3"><input class="form-control" asp-for="MinHandoverPercent" placeholder="最小移交 %" /></div>
            <div class="col-md-3"><input class="form-control" asp-for="MaxHandoverPercent" placeholder="最大移交 %" /></div>
        </div>
    </div>
    <input type="hidden" asp-for="PageSize" />
    <input type="hidden" name="PageNumber" value="1" />
</form>

<partial name="_FilterSummary" model="Model.FilterSummary" />

<form method="post" asp-page-handler="BatchDelete" class="bulk-toolbar" data-bulk-form data-confirm-message="确定刪除選中的保養訂單吗？">
    <div class="bulk-toolbar-copy">
        <span class="bulk-toolbar-count" data-selected-count>0</span>
        <span>个訂單已選擇</span>
    </div>
    <div class="bulk-toolbar-actions">
        <input type="hidden" asp-for="Year" />
        <input type="hidden" asp-for="CustomerName" />
        <input type="hidden" asp-for="Method" />
        <input type="hidden" asp-for="ExecutorUserId" />
        <input type="hidden" asp-for="MinHandoverPercent" />
        <input type="hidden" asp-for="MaxHandoverPercent" />
        <input type="hidden" asp-for="PageNumber" />
        <input type="hidden" asp-for="PageSize" />
        <button type="submit" class="btn btn-outline-danger" data-bulk-requires-selection>批量刪除</button>
    </div>
</form>

<div class="data-list-card">
    <div class="data-table-wrap">
        <table class="table table-sm table-striped align-middle data-table has-sticky-actions">
        <thead>
            <tr>
                <th class="checkbox-cell"><input class="form-check-input" type="checkbox" data-bulk-check-all /></th>
                <th>年度</th>
                <th>客戶名稱</th>
                <th>保養方式</th>
                <th>现场次數</th>
                <th>远程次數</th>
                <th>保養执行人</th>
                <th>移交百分比</th>
                <th>更新日期</th>
                <th>更新人员</th>
                <th class="text-end">操作</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var order in Model.Orders)
        {
            <tr>
                <td class="checkbox-cell"><input class="form-check-input" type="checkbox" value="@order.Id" data-bulk-checkbox /></td>
                <td>@order.Year</td>
                <td>@order.CustomerName</td>
                <td>@order.MaintenanceMethod.GetDisplayName()</td>
                <td>@order.OnSiteAnnualCount</td>
                <td>@order.RemoteAnnualCount</td>
                <td>@(order.Executor?.DisplayName ?? order.Executor?.UserName ?? order.ExecutorUserId)</td>
                <td class="numeric"><partial name="_PercentBar" model="new ProjectManager.Web.Pages.Shared.PercentBarModel(order.HandoverPercent)" /></td>
                <td>@order.UpdatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                <td>@(order.UpdatedByUser?.DisplayName ?? order.UpdatedByUser?.UserName ?? order.UpdatedByUserId)</td>
                <td class="text-end text-nowrap">
                    <a class="btn btn-sm btn-outline-secondary" asp-page="./Edit" asp-route-id="@order.Id">編輯</a>
                    <form method="post" asp-page-handler="Delete" asp-route-id="@order.Id" asp-route-Year="@Model.Year" asp-route-CustomerName="@Model.CustomerName" asp-route-Method="@Model.Method" asp-route-ExecutorUserId="@Model.ExecutorUserId" asp-route-MinHandoverPercent="@Model.MinHandoverPercent" asp-route-MaxHandoverPercent="@Model.MaxHandoverPercent" asp-route-PageNumber="@Model.PageNumber" asp-route-PageSize="@Model.PageSize" class="d-inline" onsubmit="return confirm('确定刪除该訂單吗？');">
                        <button type="submit" class="btn btn-sm btn-outline-danger">刪除</button>
                    </form>
                </td>
            </tr>
        }
        @if (!Model.Orders.Any())
        {
            <tr>
                <td colspan="11">
                    <div class="empty-state">暂无保養訂單</div>
                </td>
            </tr>
        }
        </tbody>
        </table>
    </div>
    <partial name="_Pagination" model="Model.Pagination" />
</div>
