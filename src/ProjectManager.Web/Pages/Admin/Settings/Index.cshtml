@page
@model ProjectManager.Web.Pages.Admin.Settings.IndexModel
@{
    ViewData["Title"] = "系統設定";
}

<div class="page-header">
    <div>
        <h1 class="page-title">系統設定</h1>
        <div class="page-subtitle">設定全站视觉特效等級，让不同设备和使用场景都保持舒服的交互节奏。</div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-success" role="status">@Model.StatusMessage</div>
}

<form method="post" class="form-section ui-effects-settings">
    <div class="form-section-header">
        <div>
            <div class="form-section-title">顯示主題</div>
            <div class="form-section-subtitle">目前使用的介面已設為預設主題。選擇卡片可即時預覽，儲存後套用至全站。</div>
        </div>
    </div>

    <div class="theme-option-grid" role="radiogroup" aria-label="顯示主題">
        <label class="theme-option-card" data-theme-option="theme-default">
            <input class="form-check-input" type="radio" asp-for="VisualTheme" value="Default" />
            <span class="theme-preview theme-preview-default" aria-hidden="true">
                <span class="theme-preview-sidebar"></span>
                <span class="theme-preview-window">
                    <span class="theme-preview-toolbar"></span>
                    <span class="theme-preview-content">
                        <span></span><span></span><span></span>
                    </span>
                </span>
            </span>
            <span class="theme-option-copy">
                <span class="theme-option-heading"><strong>預設主題</strong><em>目前風格</em></span>
                <span>穩重清晰的科技商務介面，保留現有色彩、卡片層次與操作習慣。</span>
            </span>
        </label>

        <label class="theme-option-card" data-theme-option="theme-clear-glass">
            <input class="form-check-input" type="radio" asp-for="VisualTheme" value="ClearGlass" />
            <span class="theme-preview theme-preview-glass" aria-hidden="true">
                <span class="theme-preview-orb theme-preview-orb-a"></span>
                <span class="theme-preview-orb theme-preview-orb-b"></span>
                <span class="theme-preview-sidebar"></span>
                <span class="theme-preview-window">
                    <span class="theme-preview-toolbar"></span>
                    <span class="theme-preview-content">
                        <span></span><span></span><span></span>
                    </span>
                </span>
            </span>
            <span class="theme-option-copy">
                <span class="theme-option-heading"><strong>清透毛玻璃</strong></span>
                <span>使用半透明材質、背景模糊、柔和高光與更圓潤的空間層次。</span>
            </span>
        </label>
    </div>

    <span asp-validation-for="VisualTheme" class="text-danger"></span>

    <div class="form-section-header mt-4">
        <div>
            <div class="form-section-title">動效風格</div>
            <div class="form-section-subtitle">選擇全站的互動語言；下方輕度、中度、高度會控制所選動效風格的運行強度。</div>
        </div>
    </div>

    <div class="motion-style-grid" role="radiogroup" aria-label="動效風格">
        <label class="motion-style-card" data-motion-option="motion-default">
            <input class="form-check-input" type="radio" asp-for="MotionStyle" value="Default" />
            <span class="motion-style-preview motion-style-preview-default" aria-hidden="true">
                <span class="motion-preview-track"><i></i></span>
                <span class="motion-preview-card motion-preview-card-a"></span>
                <span class="motion-preview-card motion-preview-card-b"></span>
            </span>
            <span class="motion-style-copy">
                <strong>預設動效</strong>
                <span>沿用目前的科技商務特效，包括流光、3D 傾斜、漣漪與線性頁面切換。</span>
            </span>
        </label>

        <label class="motion-style-card" data-motion-option="motion-apple">
            <input class="form-check-input" type="radio" asp-for="MotionStyle" value="Apple" />
            <span class="motion-style-preview motion-style-preview-apple" aria-hidden="true">
                <span class="motion-preview-glow"></span>
                <span class="motion-preview-card motion-preview-card-a"></span>
                <span class="motion-preview-card motion-preview-card-b"></span>
                <span class="motion-preview-card motion-preview-card-c"></span>
            </span>
            <span class="motion-style-copy">
                <strong>Apple 動效</strong>
                <span>使用 iOS 與 macOS 式彈性緩動、按壓縮放、柔焦入場和分層浮起效果。</span>
            </span>
        </label>
    </div>

    <span asp-validation-for="MotionStyle" class="text-danger"></span>

    <div class="form-section-header mt-4">
        <div>
            <div class="form-section-title">UI 特效运行等級</div>
            <div class="form-section-subtitle">同步控制所選動效風格在所有頁面的背景、卡片、圖表、按鈕和頁面切換強度。</div>
        </div>
    </div>

    <div class="ui-effects-level-grid" role="radiogroup" aria-label="UI 特效运行等級">
        <label class="ui-effects-level-card">
            <input class="form-check-input" type="radio" asp-for="UiEffectsLevel" value="Low" />
            <span class="ui-effects-level-copy">
                <strong>轻度</strong>
                <span>保留基礎 hover、focus 和按壓反馈，關閉持續背景、頁面轉場和重型發光動效。</span>
            </span>
        </label>
        <label class="ui-effects-level-card">
            <input class="form-check-input" type="radio" asp-for="UiEffectsLevel" value="Medium" />
            <span class="ui-effects-level-copy">
                <strong>中度</strong>
                <span>推薦預設值。啟用柔和入場、卡片浮起、數字滾動、圖表展開和彈層動效。</span>
            </span>
        </label>
        <label class="ui-effects-level-card">
            <input class="form-check-input" type="radio" asp-for="UiEffectsLevel" value="High" />
            <span class="ui-effects-level-copy">
                <strong>高度</strong>
                <span>展示感更強，啟用完整頁面轉場、背景呼吸、狀態脈衝、景深與強化彈性反馈。</span>
            </span>
        </label>
    </div>

    <span asp-validation-for="UiEffectsLevel" class="text-danger"></span>

    <div class="form-section-header mt-4">
        <div>
            <div class="form-section-title">顯示語言</div>
            <div class="form-section-subtitle">切換全系統的顯示語言（繁體中文 / 簡體中文）。儲存後立即生效。</div>
        </div>
    </div>

    <div class="ui-effects-level-grid" role="radiogroup" aria-label="顯示語言">
        <label class="ui-effects-level-card">
            <input class="form-check-input" type="radio" asp-for="DisplayLanguage" value="TraditionalChinese" />
            <span class="ui-effects-level-copy">
                <strong>繁體中文</strong>
                <span>系統預設值。所有介面文字以繁體中文顯示。</span>
            </span>
        </label>
        <label class="ui-effects-level-card">
            <input class="form-check-input" type="radio" asp-for="DisplayLanguage" value="SimplifiedChinese" />
            <span class="ui-effects-level-copy">
                <strong>簡體中文</strong>
                <span>儲存後將全站介面標題、選單、按鈕、提示和說明轉換為簡體中文。</span>
            </span>
        </label>
    </div>

    <span asp-validation-for="DisplayLanguage" class="text-danger"></span>

    <div class="form-section-header mt-4">
        <div>
            <div class="form-section-title">全局字體</div>
            <div class="form-section-subtitle">選擇全站介面字體。每個選項都包含 Windows、macOS 與 Linux 中文回退字體，不需要額外安裝，也不會因缺少單一字體而顯示亂碼。</div>
        </div>
    </div>

    <div class="font-select-panel" data-global-font-picker>
        <div class="font-select-control-wrap">
            <span class="font-select-mark" aria-hidden="true">Aa</span>
            <div class="font-select-field">
                <label class="form-label" asp-for="GlobalFont">介面字體</label>
                <select class="form-select font-select-control" asp-for="GlobalFont" data-global-font-select>
                    <option value="SystemDefault" data-font-class="font-system-default" data-preview-class="font-preview-system" data-font-name="系統預設" data-font-description="跟隨目前電腦的系統介面字體，兼容性最佳。">系統預設</option>
                    <option value="MicrosoftYaHei" data-font-class="font-microsoft-yahei" data-preview-class="font-preview-yahei" data-font-name="微軟雅黑" data-font-description="清晰現代，適合簡體中文和日常商務介面。">微軟雅黑</option>
                    <option value="MicrosoftJhengHei" data-font-class="font-microsoft-jhenghei" data-preview-class="font-preview-jhenghei" data-font-name="微軟正黑體" data-font-description="筆畫穩定，適合繁體中文和密集資料頁面。">微軟正黑體</option>
                    <option value="ChineseSerif" data-font-class="font-chinese-serif" data-preview-class="font-preview-serif" data-font-name="宋體／明體" data-font-description="傳統印刷感，適合偏正式的文字與報表閱讀。">宋體／明體</option>
                    <option value="ChineseKai" data-font-class="font-chinese-kai" data-preview-class="font-preview-kai" data-font-name="楷體" data-font-description="筆畫自然端正，適合標題、說明文字和較具人文感的介面。">楷體</option>
                </select>
            </div>
            <span class="font-select-chevron" aria-hidden="true"></span>
        </div>

        <div class="font-live-preview font-preview-system" data-global-font-preview>
            <div class="font-live-preview-head">
                <span>即時預覽</span>
                <strong data-global-font-name>系統預設</strong>
            </div>
            <p>專案管理系統 · 字體預覽 ABC 123</p>
            <small data-global-font-description>跟隨目前電腦的系統介面字體，兼容性最佳。</small>
        </div>
    </div>

    <span asp-validation-for="GlobalFont" class="text-danger"></span>

    <div class="form-section-header mt-4">
        <div>
            <div class="form-section-title">甘特圖全局檔案日期</div>
            <div class="form-section-subtitle">所有專案的甘特圖檔案日期與紅色基準線均使用此日期。</div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4">
            <label class="form-label" asp-for="ArchiveDate">檔案日期</label>
            <input class="form-control" asp-for="ArchiveDate" type="date" />
            <span asp-validation-for="ArchiveDate" class="text-danger"></span>
        </div>
    </div>

    <div class="page-actions mt-3">
        <button class="btn btn-primary" type="submit">儲存設定</button>
        <a class="btn btn-outline-secondary" asp-page="/Index">返回首頁</a>
    </div>
</form>
