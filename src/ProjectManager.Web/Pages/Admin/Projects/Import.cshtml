@page
@model ProjectManager.Web.Pages.Admin.Projects.ImportModel
@{
    ViewData["Title"] = "项目批量导入";
}

<div class="page-header">
    <div>
        <h1 class="page-title">项目批量导入</h1>
        <div class="page-subtitle">通过 Excel 快速新增或更新同年度项目基础导入字段</div>
    </div>
    <div class="page-actions">
        <a class="btn btn-outline-secondary" asp-page="./Index">返回</a>
        <a class="btn btn-outline-secondary" asp-page-handler="Template" asp-route-ImportYear="@Model.ImportYear">下载模板</a>
    </div>
</div>

<form method="post" enctype="multipart/form-data" class="form-section">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="row g-3 align-items-end">
        <div class="col-md-2">
            <label class="form-label" asp-for="ImportYear">导入年度</label>
            <input class="form-control" asp-for="ImportYear" />
            <span class="text-danger" asp-validation-for="ImportYear"></span>
        </div>
        <div class="col-md-6">
            <label class="form-label" asp-for="UploadFile">Excel 文件</label>
            <input class="form-control" asp-for="UploadFile" type="file" accept=".xlsx" />
            <span class="text-danger" asp-validation-for="UploadFile"></span>
        </div>
        <div class="col-md-4">
            <button class="btn btn-primary" type="submit">开始导入</button>
        </div>
    </div>
</form>

@if (Model.CreatedCount > 0 || Model.UpdatedCount > 0)
{
    <div class="alert alert-success">
        导入完成：新增 @Model.CreatedCount 条，更新 @Model.UpdatedCount 条。
    </div>
}

@if (Model.RowErrors.Count > 0)
{
    <section class="detail-panel">
        <h2 class="detail-panel-title">需要检查的行</h2>
        <ul class="data-exchange-errors">
            @foreach (var error in Model.RowErrors)
            {
                <li>@error</li>
            }
        </ul>
    </section>
}

<section class="detail-panel">
    <h2 class="detail-panel-title">模板字段</h2>
    <div class="data-table-wrap">
        <table class="table table-sm data-table">
            <thead>
                <tr>
                    <th>字段</th>
                    <th>说明</th>
                </tr>
            </thead>
            <tbody>
                <tr><td>工号</td><td>同一导入年度内用于判断新增或更新。</td></tr>
                <tr><td>工程名称</td><td>必填。</td></tr>
                <tr><td>项目人员</td><td>支持账号、中文姓名、邮箱或系统 ID，简繁体常见姓名可识别。</td></tr>
                <tr><td>金额</td><td>导入为项目金额。</td></tr>
                <tr><td>进度说明</td><td>支持保留允许范围内的字体颜色标记。</td></tr>
            </tbody>
        </table>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
