@page
@model ProjectManager.Web.Pages.Admin.Projects.ImportModel
@{
    ViewData["Title"] = "專案批量匯入";
}

<div class="page-header">
    <div>
        <h1 class="page-title">專案批量匯入</h1>
        <div class="page-subtitle">通過 Excel 快速新增或更新同年度專案基础匯入欄位</div>
    </div>
    <div class="page-actions">
        <a class="btn btn-outline-secondary" asp-page="./Index">返回</a>
        <a class="btn btn-outline-secondary" asp-page-handler="Template" asp-route-ImportYear="@Model.ImportYear">下載模板</a>
    </div>
</div>

<form method="post" enctype="multipart/form-data" class="form-section">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="row g-3 align-items-end">
        <div class="col-md-2">
            <label class="form-label" asp-for="ImportYear">匯入年度</label>
            <input class="form-control" asp-for="ImportYear" />
            <span class="text-danger" asp-validation-for="ImportYear"></span>
        </div>
        <div class="col-md-6">
            <label class="form-label" asp-for="UploadFile">Excel 檔案</label>
            <input class="form-control" asp-for="UploadFile" type="file" accept=".xlsx" />
            <span class="text-danger" asp-validation-for="UploadFile"></span>
        </div>
        <div class="col-md-4">
            <button class="btn btn-primary" type="submit">開始匯入</button>
        </div>
    </div>
</form>

@if (Model.CreatedCount > 0 || Model.UpdatedCount > 0)
{
    <div class="alert alert-success">
        匯入完成：新增 @Model.CreatedCount 筆，更新 @Model.UpdatedCount 筆。
    </div>
}

@if (Model.RowErrors.Count > 0)
{
    <section class="detail-panel">
        <h2 class="detail-panel-title">需要检查的行</h2>
        <ul class="data-exchange-errors">
            @foreach (var error in Model.RowErrors)
            {
                <li>@error</li>
            }
        </ul>
    </section>
}

<section class="detail-panel">
    <h2 class="detail-panel-title">模板欄位</h2>
    <div class="data-table-wrap">
        <table class="table table-sm data-table">
            <thead>
                <tr>
                    <th>欄位</th>
                    <th>說明</th>
                </tr>
            </thead>
            <tbody>
                <tr><td>項次</td><td>序號，匯入時忽略。</td></tr>
                <tr><td>工程編號</td><td>同一匯入年度內用於判斷新增或更新。</td></tr>
                <tr><td>工程名稱</td><td>必填。</td></tr>
                <tr><td>經辦</td><td>專案人員，支援帳號、中文姓名、信箱或系統 ID，簡繁體常見姓名可識別。</td></tr>
                <tr><td>專案類型</td><td>工程 / 保養，預設為工程。</td></tr>
                <tr><td>狀態說明</td><td>對應專案狀態名稱，需與系统狀態設定一致；未填寫或未匹配時使用預設狀態。</td></tr>
                <tr><td>受訂金額（含稅）</td><td>匯入為專案金額。</td></tr>
            </tbody>
        </table>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
