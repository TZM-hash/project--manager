@model ProjectManager.Web.Pages.Admin.Projects.ProjectFormPageModel

<form method="post" class="mt-3">
    <input asp-for="Input.Id" type="hidden" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="row g-3">
        <div class="col-md-2"><label class="form-label">年</label><input class="form-control" asp-for="Input.Year" /></div>
        <div class="col-md-3"><label class="form-label">母案案号</label><input class="form-control" asp-for="Input.ParentCaseNumber" /></div>
        <div class="col-md-3"><label class="form-label">项目工号</label><input class="form-control" asp-for="Input.ProjectNumber" /></div>
        <div class="col-md-4"><label class="form-label">项目名称</label><input class="form-control" asp-for="Input.Name" /></div>
        <div class="col-md-4">
            <label class="form-label">状态</label>
            <select class="form-select" asp-for="Input.StatusId" asp-items="Model.StatusOptions"></select>
        </div>
        <div class="col-md-4">
            <label class="form-label">专案人员</label>
            <select class="form-select" asp-for="Input.AssignedUserIds" asp-items="Model.UserOptions" multiple></select>
        </div>
        <div class="col-md-4"><label class="form-label">结案日期</label><input class="form-control" asp-for="Input.ClosedYearMonth" type="month" /></div>
        <div class="col-md-3"><label class="form-label">专案进度 %</label><input class="form-control" asp-for="Input.ProgressPercent" /></div>
        <div class="col-md-3"><label class="form-label">专案金额</label><input class="form-control" asp-for="Input.ProjectAmount" /></div>
        <div class="col-md-3"><label class="form-label">收款比例 %</label><input class="form-control" asp-for="Input.CollectionPercent" /></div>
        <div class="col-md-12"><label class="form-label">进度说明</label><textarea class="form-control" asp-for="Input.ProgressDescription"></textarea></div>
    </div>

    <h2 class="h5 mt-4">请购记录</h2>
    <table class="table table-sm align-middle">
        <thead>
            <tr>
                <th>请购号</th>
                <th>类型</th>
                <th>请购人员</th>
                <th>金额</th>
                <th>子案对接人员</th>
                <th>付款比例</th>
                <th>实际已付款</th>
                <th>备注</th>
                <th>删除</th>
            </tr>
        </thead>
        <tbody>
        @for (var i = 0; i < Model.Input.Purchases.Count; i++)
        {
            <tr>
                <td>
                    <input asp-for="Input.Purchases[i].Id" type="hidden" />
                    <input class="form-control form-control-sm" asp-for="Input.Purchases[i].RequestNumber" />
                </td>
                <td><select class="form-select form-select-sm" asp-for="Input.Purchases[i].PurchaseType" asp-items="Model.PurchaseTypeOptions"></select></td>
                <td><select class="form-select form-select-sm" asp-for="Input.Purchases[i].PurchaseStaffUserId" asp-items="Model.UserOptions"><option value="">-</option></select></td>
                <td><input class="form-control form-control-sm" asp-for="Input.Purchases[i].PurchaseAmount" /></td>
                <td><select class="form-select form-select-sm" asp-for="Input.Purchases[i].SubCaseContactUserId" asp-items="Model.UserOptions"><option value="">-</option></select></td>
                <td><input class="form-control form-control-sm" asp-for="Input.Purchases[i].PaymentPercent" /></td>
                <td><input class="form-control form-control-sm" asp-for="Input.Purchases[i].ActualPaidAmount" /></td>
                <td><input class="form-control form-control-sm" asp-for="Input.Purchases[i].Notes" /></td>
                <td>
                    @if (Model.Input.Purchases[i].Id > 0)
                    {
                        <input class="form-check-input" asp-for="Input.Purchases[i].IsDeleted" />
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>

    <div class="mt-4">
        <button type="submit" class="btn btn-primary">保存</button>
        <a class="btn btn-outline-secondary" asp-page="./Index">返回</a>
    </div>
</form>
