                        <button type="button" class="dropdown-item" data-column-manager-none">全不選</button>
                    </div>
                </div>
                <div class="dropdown" data-row-spacing>
                    <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-row-spacing-toggle>
                        <svg class="nav-icon" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="3" x2="12" y2="21"/><line x1="3" y1="12" x2="21" y2="12"/></svg>
                        行間距
                    </button>
                    <div class="dropdown-menu dropdown-menu-end p-2">
                        <button type="button" class="dropdown-item" data-row-spacing-option="compact">緊湊</button>
