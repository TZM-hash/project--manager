@page
@model ProjectManager.Web.Pages.Admin.Projects.IndexModel
@using ProjectManager.Web.Extensions
@{
    ViewData["Title"] = "專案總覽";
}

<div class="page-header">
    <div>
        <h1 class="page-title">專案管理</h1>
        <div class="page-subtitle">维护專案主档、請購記錄、進度和狀態資料</div>
    </div>
    <div class="page-actions">
        <button type="button" class="btn btn-outline-secondary" onclick="openReport()">報表列印</button>
        <a class="btn btn-outline-secondary" asp-page="./Import">Excel 批量匯入</a>
        <a class="btn btn-outline-success" asp-page="./Index" asp-route-handler="ExportExcel">專案Excel下載</a>
        <a class="btn btn-primary" asp-page="./Create">新增專案</a>
    </div>
</div>

<div class="metric-grid dashboard-grid">
    @foreach (var metric in Model.Metrics)
    {
        <div class="metric-card metric-@metric.Accent">
            <div class="metric-label">@metric.Label</div>
            <div class="metric-value" data-countup>@metric.Value</div>
            <div class="metric-hint">@metric.Hint</div>
        </div>
    }
</div>

<div class="insight-grid">
    <section class="chart-card">
        <div class="chart-card-header">
            <div>
                <div class="chart-title">狀態分布</div>
                <div class="chart-subtitle">按当前篩選筆件統計</div>
            </div>
        </div>
        <div class="bar-list">
            @foreach (var slice in Model.StatusSlices)
            {
                <div class="bar-row" style="--bar-width:@slice.Percent%;--bar-color:@slice.Color">
                    <div class="bar-row-label">@slice.Label</div>
                    <div class="bar-track"><span></span></div>
                    <div class="bar-value">@slice.Value.ToString("0")</div>
                </div>
            }
        </div>
    </section>
    <section class="chart-card">
        <div class="chart-card-header">
            <div>
                <div class="chart-title">進度区间</div>
                <div class="chart-subtitle">识别推进节奏和完工占比</div>
            </div>
        </div>
        <div class="bar-list">
            @foreach (var slice in Model.ProgressSlices)
            {
                <div class="bar-row" style="--bar-width:@slice.Percent%;--bar-color:@slice.Color">
                    <div class="bar-row-label">@slice.Label</div>
                    <div class="bar-track"><span></span></div>
                    <div class="bar-value">@slice.Value.ToString("0")</div>
                </div>
            }
        </div>
    </section>
</div>

<form method="get" class="filter-panel advanced-filter-panel" data-filter-drawer>
    <div class="filter-quick-row">
        <div class="filter-quick-main">
            <input class="form-control" asp-for="ProjectName" placeholder="搜尋專案名稱" />
            <input class="form-control" asp-for="ProjectNumber" placeholder="專案工號" />
        </div>
        <div class="filter-quick-actions">
            <button class="btn btn-outline-secondary" type="button" data-filter-drawer-toggle>進階篩選</button>
            <button class="btn btn-primary" type="submit">查詢</button>
        </div>
    </div>
    <div class="filter-drawer" data-filter-drawer-panel>
        <div class="filter-drawer-header">
            <div>
                <div class="filter-drawer-title">進階篩選</div>
                <div class="filter-drawer-subtitle">按年度、母案、人员、狀態和结案範圍精确定位專案</div>
            </div>
            <button class="btn btn-sm btn-outline-secondary" type="button" data-filter-drawer-close>收起</button>
        </div>
        <div class="row g-2">
            <div class="col-md-2"><input class="form-control" asp-for="Year" placeholder="年" /></div>
            <div class="col-md-3"><input class="form-control" asp-for="ParentCaseNumber" placeholder="母案案號" /></div>
            <div class="col-md-3">
                <select class="form-select" asp-for="PersonnelUserId" asp-items="Model.UserOptions">
                </select>
            </div>
            <div class="col-md-2">
                <select class="form-select" asp-for="StatusId" asp-items="Model.StatusOptions">
                    <option value="">狀態</option>
                </select>
            </div>
            <div class="col-md-2">
                <select class="form-select" asp-for="ProjectType" asp-items="Model.ProjectTypeOptions">
                    <option value="">專案類型</option>
                </select>
            </div>
            <div class="col-md-2">
                <select class="form-select" asp-for="OpenOnly">
                    <option value="false">全部</option>
                    <option value="true">未結案</option>
                </select>
            </div>
        </div>
    </div>
    <input type="hidden" asp-for="PageSize" />
    <input type="hidden" name="PageNumber" value="1" />
</form>

<partial name="_FilterSummary" model="Model.FilterSummary" />

<div class="detail-tab-shell mb-3">
    <div class="detail-tabs" role="tablist" aria-label="專案管理分區">
        <a class="detail-tab @(Model.ActiveTab != "engineering" && Model.ActiveTab != "pending-closure" && Model.ActiveTab != "waiting-collection" ? "is-active" : "")" href="/Admin/Projects/Index?@BuildTabQueryString(Model, "overview")">總覽</a>
        <a class="detail-tab @(Model.ActiveTab == "engineering" ? "is-active" : "")" href="/Admin/Projects/Index?@BuildTabQueryString(Model, "engineering")">實施中（工程）</a>
        <a class="detail-tab @(Model.ActiveTab == "pending-closure" ? "is-active" : "")" href="/Admin/Projects/Index?@BuildTabQueryString(Model, "pending-closure")">待結案</a>
        <a class="detail-tab @(Model.ActiveTab == "waiting-collection" ? "is-active" : "")" href="/Admin/Projects/Index?@BuildTabQueryString(Model, "waiting-collection")">待收款</a>
    </div>
</div>

@functions {
    private static string BuildTabQueryString(IndexModel model, string tab)
    {
        var values = new Dictionary<string, string?>
        {
            [nameof(model.ActiveTab)] = tab,
            [nameof(model.Year)] = model.Year?.ToString(),
            [nameof(model.ParentCaseNumber)] = model.ParentCaseNumber,
            [nameof(model.ProjectNumber)] = model.ProjectNumber,
            [nameof(model.ProjectName)] = model.ProjectName,
            [nameof(model.PersonnelUserId)] = model.PersonnelUserId,
            [nameof(model.StatusId)] = model.StatusId?.ToString(),
            [nameof(model.ProjectType)] = model.ProjectType.HasValue ? ((int)model.ProjectType.Value).ToString() : null,
            [nameof(model.OpenOnly)] = model.OpenOnly.ToString(),
            [nameof(model.PageSize)] = model.PageSize.ToString()
        };
        return string.Join("&", values.Where(x => !string.IsNullOrWhiteSpace(x.Value)).Select(x => $"{Uri.EscapeDataString(x.Key)}={Uri.EscapeDataString(x.Value!)}"));
    }
}

@if (Model.ActiveTab == "engineering")
{
    <div class="metric-grid dashboard-grid mb-3">
        <div class="metric-card metric-info">
            <div class="metric-label">自理專案</div>
            <div class="metric-value">@Model.SelfManagedProjectCount.ToString("N0")</div>
            <div class="metric-hint">無廠商資料</div>
        </div>
        <div class="metric-card metric-primary">
            <div class="metric-label">專案總覽</div>
            <div class="metric-value">@Model.ManagedProjectCount.ToString("N0")</div>
            <div class="metric-hint">有廠商資料</div>
        </div>
    </div>

    <div class="data-list-card">
        <div class="data-table-wrap">
            <div class="d-flex justify-content-end mb-2 gap-2">
                <div class="dropdown" data-column-manager>
                    <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false" data-column-manager-toggle>
                        <svg class="nav-icon" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                        列管理
                    </button>
                    <div class="dropdown-menu dropdown-menu-end p-2" data-column-manager-list>
                        <div class="dropdown-divider"></div>
                        <button type="button" class="dropdown-item" data-column-manager-all">全選</button>
                        <button type="button" class="dropdown-item" data-column-manager-none">全不選</button>
                    </div>
                </div>
                <div class="dropdown" data-row-spacing>
                    <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-row-spacing-toggle>
                        <svg class="nav-icon" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="3" x2="12" y2="21"/><line x1="3" y1="12" x2="21" y2="12"/></svg>
                        行間距
                    </button>
                    <div class="dropdown-menu dropdown-menu-end p-2">
                        <button type="button" class="dropdown-item" data-row-spacing-option="compact">緊湊</button>
                        <button type="button" class="dropdown-item" data-row-spacing-option="normal">預設</button>
                        <button type="button" class="dropdown-item" data-row-spacing-option="spacious">寬鬆</button>
                    </div>
                </div>
            </div>
            <table class="table table-sm table-striped align-middle data-table has-sticky-actions" data-column-manager-table>
                <thead>
                    <tr>
                        <th data-column="index">項次</th>
                        <th data-column="projectNumber">工程編號</th>
                        <th data-column="projectName" style="min-width: 180px;">專案名稱</th>
                        <th data-column="assignee">經辦</th>
                        <th data-column="vendor">廠商</th>
                        <th data-column="trialRunTime">預計試車時間</th>
                        <th data-column="progress">工程進度</th>
                        <th data-column="progressDesc">進度說明</th>
                        <th data-column="projectType">專案類型</th>
                        <th data-column="actions" class="text-end">操作</th>
                        <th data-column="parentCase" style="min-width: 120px;">母案案號</th>
                        <th data-column="status">狀態</th>
                    </tr>
                </thead>
                <tbody>
                @for (var i = 0; i < Model.EngineeringProjects.Count; i++)
                {
                    var project = Model.EngineeringProjects[i];
                    <tr>
                        <td data-column="index">@(i + 1)</td>
                        <td data-column="projectNumber">@project.ProjectNumber</td>
                        <td data-column="projectName">@project.Name</td>
                        <td data-column="assignee">@string.Join("；", project.Assignments.Select(x => x.User?.DisplayName ?? x.User?.UserName ?? x.UserId))</td>
                        <td data-column="vendor">@(string.IsNullOrWhiteSpace(project.VendorName) ? "無" : project.VendorName)</td>
                        <td data-column="trialRunTime">
                            @if (project.TrialRunYearMonth.HasValue)
                            {
                                var isCompleted = project.ProgressPercent >= 100 || (project.Status?.IsClosed == true);
                                <span>@project.TrialRunYearMonth.Value.ToString("yyyy-MM")</span>
                                @if (isCompleted)
                                {
                                    <span class="text-success">（已完成）</span>
                                }
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td data-column="progress" class="numeric"><partial name="_PercentBar" model="new ProjectManager.Web.Pages.Shared.PercentBarModel(project.ProgressPercent)" /></td>
                        <td data-column="progressDesc">@Html.Raw(project.ProgressDescription?.Replace("\n", "<br/>") ?? "-")</td>
                        <td data-column="projectType">@project.ProjectType.GetDisplayName()</td>
                        <td data-column="actions" class="text-end text-nowrap">
                            <a class="btn btn-sm btn-outline-secondary" asp-page="./Edit" asp-route-id="@project.Id" asp-route-returnTab="engineering">編輯</a>
                        </td>
                        <td data-column="parentCase">@project.ParentCaseNumber</td>
                        <td data-column="status"><partial name="_StatusBadge" model="project.Status" /></td>
                    </tr>
                }
                @if (!Model.EngineeringProjects.Any())
                {
                    <tr>
                        <td colspan="12">
                            <div class="empty-state">暫無實施中工程類專案</div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
}
