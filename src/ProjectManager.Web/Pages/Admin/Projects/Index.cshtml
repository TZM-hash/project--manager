                    </tr>
                }
                @if (!Model.WaitingCollectionProjects.Any())
                {
                    <tr>
                        <td colspan="11">
                            <partial name="_EmptyState" model='new ProjectManager.Web.Pages.Shared.EmptyStateViewModel(
                                "目前沒有待收款專案",
                                "需要追蹤收款的專案會集中顯示在這裡。",
                                "inbox")' />
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <form method="post" asp-page-handler="BatchDelete" class="bulk-toolbar" data-bulk-form data-confirm-message="確定刪除選中的專案嗎？">
    <div class="bulk-toolbar-copy">
        <span class="bulk-toolbar-count" data-selected-count>0</span>
        <span>項已選擇</span>
    </div>
    <div class="bulk-toolbar-actions">
        <input type="hidden" asp-for="Year" />
        <input type="hidden" asp-for="ParentCaseNumber" />
        <input type="hidden" asp-for="ProjectNumber" />
        <input type="hidden" asp-for="ProjectName" />
        <input type="hidden" asp-for="PersonnelUserId" />
        <input type="hidden" asp-for="StatusId" />
        <input type="hidden" asp-for="ProjectType" />
        <input type="hidden" asp-for="OpenOnly" />
        <input type="hidden" asp-for="PageNumber" />
        <input type="hidden" asp-for="PageSize" />
        <button type="submit" class="btn btn-outline-danger" data-bulk-requires-selection data-processing-label="正在刪除…">批量刪除</button>
    </div>
</form>

<div class="data-list-card">
        <div class="metric-grid dashboard-grid mb-3" style="grid-template-columns: repeat(3, minmax(0, 1fr));">
            <div class="metric-card metric-primary">
                <div class="metric-label">專案合計</div>
                <div class="metric-value" data-countup>@Model.TotalProjectCount.ToString("N0")</div>
            </div>
            <div class="metric-card metric-info">
                <div class="metric-label">工程類專案</div>
                <div class="metric-value" data-countup>@Model.EngineeringProjectCount.ToString("N0")</div>
            </div>
            <div class="metric-card metric-success">
                <div class="metric-label">保養類專案</div>
                <div class="metric-value" data-countup>@Model.MaintenanceProjectCount.ToString("N0")</div>
            </div>
        </div>
        <div class="data-table-wrap">
            <div class="d-flex justify-content-end mb-2 gap-2">
                <div class="dropdown" data-row-spacing>
                    <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-row-spacing-toggle>
                        <svg class="nav-icon" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="3" x2="12" y2="21"/><line x1="3" y1="12" x2="21" y2="12"/></svg>
                        行間距
                    </button>
                    <div class="dropdown-menu dropdown-menu-end p-2">
                        <button type="button" class="dropdown-item" data-row-spacing-option="compact">緊湊</button>
                        <button type="button" class="dropdown-item" data-row-spacing-option="normal">預設</button>
                        <button type="button" class="dropdown-item" data-row-spacing-option="spacious">寬鬆</button>
                    </div>
                </div>
                <div class="dropdown" data-column-manager>
                    <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-column-manager-toggle>
                        <svg class="nav-icon" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
                        列管理
                    </button>
                    <div class="dropdown-menu dropdown-menu-end p-3 column-manager-menu" style="min-width: 240px; max-height: 400px; overflow-y: auto;">
                        <div class="d-flex justify-content-between align-items-center mb-2 pb-2 border-bottom">
                            <strong>顯示欄位</strong>
                            <div>
                                <button type="button" class="btn btn-sm btn-link p-0 me-2" data-column-manager-all>全選</button>
                                <button type="button" class="btn btn-sm btn-link p-0" data-column-manager-none>全不選</button>
                            </div>
                        </div>
                        <div data-column-manager-list>
                        </div>
                    </div>
                </div>
            </div>
            <table class="table table-sm table-striped align-middle data-table has-sticky-actions"
                   data-column-manager-table
                   data-initial-visible-columns='@System.Text.Json.JsonSerializer.Serialize(Model.SavedViewBar.VisibleColumns)'
                   data-initial-row-density="@Model.SavedViewBar.RowDensity">
                <thead>
                    <tr>
                        <th class="checkbox-cell" data-column="checkbox" data-column-label="選取" data-column-fixed><input class="form-check-input" type="checkbox" data-bulk-check-all aria-label="選擇全部專案" /></th>
                        <th data-column="item" data-column-label="項次" data-column-fixed>項次</th>
                        <th data-column="projectNumber" data-column-label="專案工號" data-column-fixed>專案工號</th>
                        <th data-column="name" data-column-label="專案名稱" data-column-fixed style="min-width: 180px;">專案名稱</th>
                        <th data-column="assignments" data-column-label="專案人員">專案人員</th>
                        <th data-column="projectType" data-column-label="專案類型">專案類型</th>
                        <th data-column="status" data-column-label="狀態">狀態</th>
                        <th data-column="projectAmount" data-column-label="專案金額" class="numeric">專案金額（含稅）</th>
                        <th data-column="progress" data-column-label="進度" class="numeric">進度</th>
                        <th data-column="collection" data-column-label="收款比例" class="numeric">收款比例</th>
                        <th data-column="updatedAt" data-column-label="最後更新時間">最後更新時間</th>
                        <th data-column="actions" data-column-label="操作" data-column-fixed class="text-end">操作</th>
                        <th data-column="parentCaseNumber" data-column-label="母案案號" style="min-width: 120px;">母案案號</th>
                    </tr>
                </thead>
                <tbody>
                    @for (var i = 0; i < Model.Projects.Count; i++)
                    {
                        var project = Model.Projects[i];
                        <tr>
                            <td class="checkbox-cell" data-column="checkbox"><input class="form-check-input" type="checkbox" value="@project.Id" data-bulk-checkbox aria-label="選擇專案 @project.ProjectNumber" /></td>
                            <td data-column="item">@(i + 1)</td>
                            <td data-column="projectNumber">@project.ProjectNumber</td>
                            <td data-column="name">@project.Name</td>
                            <td data-column="assignments">@string.Join("；", project.Assignments.Select(x => x.User?.DisplayName ?? x.User?.UserName ?? x.UserId))</td>
                            <td data-column="projectType">@project.ProjectType.GetDisplayName()</td>
                            <td data-column="status"><partial name="_StatusBadge" model="project.Status" /></td>
                            <td data-column="projectAmount" class="numeric">@project.ProjectAmount.ToString("N0")</td>
                            <td data-column="progress" class="numeric"><partial name="_PercentBar" model="new ProjectManager.Web.Pages.Shared.PercentBarModel(project.ProgressPercent)" /></td>
                            <td data-column="collection" class="numeric"><partial name="_PercentBar" model="new ProjectManager.Web.Pages.Shared.PercentBarModel(project.CollectionPercent)" /></td>
                            <td data-column="updatedAt" class="text-nowrap">@project.UpdatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                            <td data-column="actions" class="text-end text-nowrap">
                                <a class="btn btn-sm btn-outline-secondary" asp-page="./Details" asp-route-id="@project.Id">明細</a>
                                <a class="btn btn-sm btn-outline-secondary" asp-page="./Edit" asp-route-id="@project.Id">編輯</a>
                                @if (Model.CanArchiveProject(project))
                                {
                                    <form method="post" asp-page-handler="Archive" asp-route-id="@project.Id" class="d-inline" onsubmit="return confirm('確定歸檔該專案嗎？歸檔後專案將移至歷史記錄，無法恢復。');">
                                        <button type="submit" class="btn btn-sm btn-outline-warning">歸檔</button>
                                    </form>
                                }
                                <form method="post" asp-page="./Edit" asp-page-handler="Delete" asp-route-id="@project.Id" class="d-inline" onsubmit="return confirm('確定刪除該專案嗎？');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger" aria-label="刪除專案 @project.ProjectNumber">刪除</button>
                                </form>
                            </td>
                            <td data-column="parentCaseNumber">@project.ParentCaseNumber</td>
                        </tr>
                    }
                    @if (!Model.Projects.Any())
                    {
                        <tr>
                            <td colspan="13">
                                <partial name="_EmptyState" model='new ProjectManager.Web.Pages.Shared.EmptyStateViewModel(
                                    "沒有符合條件的專案",
                                    "請調整目前篩選條件，或建立新的專案資料。",
                                    "search",
                                    "新增專案",
                                    "/Admin/Projects/Create",
                                    ClearActionText: "清除篩選",
                                    ClearActionPage: "/Admin/Projects/Index")' />
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr class="table-secondary">
                        <td colspan="7" class="text-end"><strong>目前合計專案金額（含稅）</strong></td>
                        <td class="numeric"><strong>@Model.Projects.Sum(x => x.ProjectAmount).ToString("N0")</strong></td>
                        <td colspan="5"></td>
                    </tr>
                </tfoot>
            </table>
        </div>

    <partial name="_Pagination" model="Model.Pagination" />
</div>
}

@section Scripts {
<script>
function openReport() {
    var checked = document.querySelectorAll('[data-bulk-checkbox]:checked');
    var base = '@Url.Page("./Report")';
    var params = new URLSearchParams();

    params.set('ReportType', '@Model.ActiveTab');

    if (checked.length > 0) {
        checked.forEach(function(cb) {
            params.append('SelectedIds', cb.value);
        });
    } else {
        var filters = {
            Year: '@Model.Year',
            ParentCaseNumber: '@Model.ParentCaseNumber',
            ProjectNumber: '@Model.ProjectNumber',
            ProjectName: '@Model.ProjectName',
            PersonnelUserId: '@Model.PersonnelUserId',
            StatusId: '@Model.StatusId',
            ProjectType: '@Model.ProjectType',
            OpenOnly: '@Model.OpenOnly'
        };
        for (var key in filters) {
            if (filters[key] && filters[key] !== '') {
                params.set(key, filters[key]);
            }
        }
    }

    params.set('_t', Date.now());
    window.open(base + '?' + params.toString(), '_blank');
}
</script>
}
