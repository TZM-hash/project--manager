                    </div>
                </div>
            </div>
            <table class="table table-sm table-striped align-middle data-table has-sticky-actions" data-column-manager-table>
                <thead>
                    <tr>
                        <th data-column="index">項次</th>
                        <th data-column="projectNumber">工程編號</th>
                        <th data-column="projectName" style="min-width: 180px;">專案名稱</th>
                        <th data-column="assignee">經辦</th>
                        <th data-column="progressDesc">進度說明</th>
                        <th data-column="collectionPercent">收款比例</th>
                        <th data-column="progress">工程進度</th>
                        <th data-column="risk">推進判斷</th>
                        <th data-column="projectType">專案類型</th>
                        <th data-column="actions" class="text-end">操作</th>
                    </tr>
                </thead>
                <tbody>
                @for (var i = 0; i < Model.PendingClosureProjects.Count; i++)
                {
                    var project = Model.PendingClosureProjects[i];
                    <tr>
                        <td data-column="index">@(i + 1)</td>
                        <td data-column="projectNumber">@project.ProjectNumber</td>
                        <td data-column="projectName">@project.Name</td>
                        <td data-column="assignee">@string.Join("；", project.Assignments.Select(x => x.User?.DisplayName ?? x.User?.UserName ?? x.UserId))</td>
                        <td data-column="progressDesc"><span class="table-text-clamp" data-full-text="@project.ProgressDescription">@(string.IsNullOrWhiteSpace(project.ProgressDescription) ? "—" : project.ProgressDescription)</span></td>
                        <td data-column="collectionPercent" class="numeric"><partial name="_PercentBar" model="new ProjectManager.Web.Pages.Shared.PercentBarModel(project.CollectionPercent)" /></td>
                        <td data-column="progress" class="numeric"><partial name="_PercentBar" model="new ProjectManager.Web.Pages.Shared.PercentBarModel(project.ProgressPercent)" /></td>
                        <td data-column="risk"><partial name="_ProgressRiskBadge" model="project" /></td>
                        <td data-column="projectType">@project.ProjectType.GetDisplayName()</td>
                        <td data-column="actions" class="text-end text-nowrap">
                            <a class="btn btn-sm btn-outline-secondary" asp-page="./Edit" asp-route-id="@project.Id">編輯</a>
                        </td>
                    </tr>
                }
                @if (!Model.PendingClosureProjects.Any())
                {
                    <tr>
                        <td colspan="10">
                            <partial name="_EmptyState" model='new ProjectManager.Web.Pages.Shared.EmptyStateViewModel(
                                "目前沒有待結案專案",
                                "符合待結案條件的專案會集中顯示在這裡。",
                                "inbox")' />
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
