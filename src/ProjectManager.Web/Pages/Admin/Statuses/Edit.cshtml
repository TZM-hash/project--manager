@page "{id:int?}"
@model ProjectManager.Web.Pages.Admin.Statuses.EditModel
@{
    ViewData["Title"] = Model.Input.Id == 0 ? "新增狀態" : "編輯狀態";
}

<div class="page-header">
    <div>
        <h1 class="page-title">@ViewData["Title"]</h1>
        <div class="page-subtitle">调整狀態名稱、顺序、结案規則和顯示样式</div>
    </div>
</div>

<form method="post" class="form-section">
    <input asp-for="Input.Id" type="hidden" />
    <div asp-validation-summary="All" class="text-danger"></div>
    <div class="row g-3">
        <div class="col-md-3">
            <label class="form-label" asp-for="Input.Code">代码</label>
            <input class="form-control" asp-for="Input.Code" />
            <span class="text-danger" asp-validation-for="Input.Code"></span>
        </div>
        <div class="col-md-3">
            <label class="form-label" asp-for="Input.Name">狀態名稱</label>
            <input class="form-control" asp-for="Input.Name" />
            <span class="text-danger" asp-validation-for="Input.Name"></span>
        </div>
        <div class="col-md-2">
            <label class="form-label" asp-for="Input.SortOrder">排序</label>
            <input class="form-control" asp-for="Input.SortOrder" />
        </div>
        <div class="col-md-2">
            <label class="form-label" asp-for="Input.TextColor">文字顏色</label>
            <input class="form-control form-control-color" asp-for="Input.TextColor" type="color" />
        </div>
        <div class="col-md-2">
            <label class="form-label" asp-for="Input.BackgroundColor">背景顏色</label>
            <input class="form-control form-control-color" asp-for="Input.BackgroundColor" type="color" />
        </div>
        <div class="col-md-12 d-flex gap-4">
            <label class="form-check-label">
                <input class="form-check-input" asp-for="Input.IsClosed" />
                结案狀態
            </label>
            <label class="form-check-label">
                <input class="form-check-input" asp-for="Input.IsActive" />
                啟用
            </label>
            <label class="form-check-label">
                <input class="form-check-input" asp-for="Input.IsBold" />
                字体加粗
            </label>
        </div>
    </div>
    <div class="mt-4">
        <button type="submit" class="btn btn-primary" data-processing-label="正在儲存…">儲存</button>
        <a class="btn btn-outline-secondary" asp-page="./Index">返回</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
