@page "{id}"
@using ProjectManager.Web.Security
@model ProjectManager.Web.Pages.Admin.Users.EditModel
@{
    ViewData["Title"] = "编辑用户";
}

<div class="page-header">
    <div>
        <h1 class="page-title">编辑用户</h1>
        <div class="page-subtitle">更新账号资料、启用状态和角色权限</div>
    </div>
</div>

<form method="post" class="form-section">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="row g-3">
        <div class="col-md-4">
            <label asp-for="Input.UserName" class="form-label">用户名</label>
            <input asp-for="Input.UserName" class="form-control" readonly />
        </div>
        <div class="col-md-4">
            <label asp-for="Input.DisplayName" class="form-label">姓名</label>
            <input asp-for="Input.DisplayName" class="form-control" />
        </div>
        <div class="col-md-4">
            <label asp-for="Input.Email" class="form-label">邮箱</label>
            <input asp-for="Input.Email" class="form-control" />
        </div>
        <div class="col-12">
            <label class="form-check-label">
                <input asp-for="Input.IsActive" class="form-check-input" />
                启用账号
            </label>
        </div>
        <div class="col-12">
            <label class="form-check-label">
                <input asp-for="Input.IsWeakManaged" class="form-check-input" />
                弱管理（不强制密码/邮箱）
            </label>
        </div>
        <div class="col-12">
            <label class="form-label">角色</label>
            <div class="d-flex flex-wrap gap-3">
                @foreach (var role in Model.AvailableRoles)
                {
                    <label class="form-check-label">
                        <input class="form-check-input" type="checkbox" name="Input.SelectedRoles" value="@role" checked="@Model.Input.SelectedRoles.Contains(role)" />
                        @RoleNames.GetDisplayName(role)
                    </label>
                }
            </div>
        </div>
    </div>
    <div class="mt-4">
        <button type="submit" class="btn btn-primary">保存</button>
        <a class="btn btn-outline-secondary" asp-page="./Index">返回</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
