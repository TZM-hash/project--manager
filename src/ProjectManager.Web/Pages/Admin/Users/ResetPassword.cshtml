@page "{id}"
@model ProjectManager.Web.Pages.Admin.Users.ResetPasswordModel
@{
    ViewData["Title"] = "重置密码";
}

<h1 class="h3">重置密码</h1>

<form method="post" class="mt-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-3">
        <label asp-for="Input.NewPassword" class="form-label">新密码</label>
        <input asp-for="Input.NewPassword" class="form-control" type="password" />
        <span asp-validation-for="Input.NewPassword" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">重置</button>
    <a class="btn btn-outline-secondary" asp-page="./Index">返回</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
