@page
@using ProjectManager.Web.Security
@model ProjectManager.Web.Pages.Admin.Users.IndexModel
@{
    ViewData["Title"] = "用户管理";
}

<div class="page-header">
    <div>
        <h1 class="page-title">用户管理</h1>
        <div class="page-subtitle">维护账号启用状态、角色和密码重置</div>
    </div>
    <div class="page-actions">
        <a class="btn btn-primary" asp-page="./Create">新增用户</a>
    </div>
</div>

<div class="data-table-wrap">
    <table class="table table-sm table-striped align-middle data-table">
        <thead>
            <tr>
                <th>用户名</th>
                <th>姓名</th>
                <th>邮箱</th>
                <th>启用</th>
                <th>角色</th>
                <th class="text-end">操作</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var user in Model.Users)
        {
            <tr>
                <td>@user.UserName</td>
                <td>@user.DisplayName</td>
                <td>@user.Email</td>
                <td>@(user.IsActive ? "是" : "否")</td>
                <td>@string.Join("、", user.Roles.Select(RoleNames.GetDisplayName))</td>
                <td class="text-end text-nowrap">
                    <a class="btn btn-sm btn-outline-secondary" asp-page="./Edit" asp-route-id="@user.Id">编辑</a>
                    <a class="btn btn-sm btn-outline-secondary" asp-page="./ResetPassword" asp-route-id="@user.Id">重置密码</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
