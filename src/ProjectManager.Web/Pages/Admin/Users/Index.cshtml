@page
@using ProjectManager.Web.Security
@model ProjectManager.Web.Pages.Admin.Users.IndexModel
@{
    ViewData["Title"] = "使用者管理";
}

<div class="page-header">
    <div>
        <h1 class="page-title">使用者管理</h1>
        <div class="page-subtitle">维护帳號啟用狀態、角色和密碼重設</div>
    </div>
    <div class="page-actions">
        <a class="btn btn-primary" asp-page="./Create">新增使用者</a>
    </div>
</div>

<div class="metric-grid dashboard-grid">
    @foreach (var metric in Model.Metrics)
    {
        <div class="metric-card metric-@metric.Accent">
            <div class="metric-label">@metric.Label</div>
            <div class="metric-value" data-countup>@metric.Value</div>
            <div class="metric-hint">@metric.Hint</div>
        </div>
    }
</div>

<div class="insight-grid">
    <section class="chart-card">
        <div class="chart-title">啟用狀態</div>
        <div class="chart-subtitle">帳號可用性概覽</div>
        <div class="donut-wrap">
            <div class="donut-chart" style="--donut-color:@(Model.ActiveSlices.FirstOrDefault()?.Color ?? "#2563eb");--donut-percent:@(Model.ActiveSlices.FirstOrDefault()?.Percent ?? 0)">
                <span>@(Model.ActiveSlices.FirstOrDefault()?.Percent.ToString("0.#") ?? "0")%</span>
            </div>
            <div class="legend-list">
                @foreach (var slice in Model.ActiveSlices)
                {
                    <div class="legend-item"><span style="background:@slice.Color"></span>@slice.Label @slice.Value.ToString("0")</div>
                }
            </div>
        </div>
    </section>
    <section class="chart-card">
        <div class="chart-title">角色分佈</div>
        <div class="chart-subtitle">依帳號角色統計</div>
        <div class="bar-list">
            @foreach (var slice in Model.RoleSlices)
            {
                <div class="bar-row" style="--bar-width:@slice.Percent%;--bar-color:@slice.Color">
                    <div class="bar-row-label">@slice.Label</div>
                    <div class="bar-track"><span></span></div>
                    <div class="bar-value">@slice.Value.ToString("0")</div>
                </div>
            }
        </div>
    </section>
</div>

<form method="get" class="filter-panel advanced-filter-panel" data-filter-drawer>
    <div class="filter-quick-row">
        <div class="filter-quick-main">
            <input class="form-control" asp-for="Keyword" placeholder="搜尋使用者名稱、姓名、信箱" />
            <select class="form-select" asp-for="IsActive">
                <option value="">啟用狀態</option>
                <option value="true">啟用</option>
                <option value="false">停用</option>
            </select>
        </div>
        <div class="filter-quick-actions">
            <button class="btn btn-outline-secondary" type="button" data-filter-drawer-toggle>進階篩選</button>
            <button class="btn btn-primary" type="submit">查詢</button>
        </div>
    </div>
    <div class="filter-drawer" data-filter-drawer-panel>
        <div class="filter-drawer-header">
            <div>
                <div class="filter-drawer-title">進階篩選</div>
                <div class="filter-drawer-subtitle">依角色和弱管理標記縮小使用者範圍</div>
            </div>
            <button class="btn btn-sm btn-outline-secondary" type="button" data-filter-drawer-close>收起</button>
        </div>
        <div class="row g-2">
            <div class="col-md-4">
                <select class="form-select" asp-for="RoleName" asp-items="Model.RoleOptions">
                    <option value="">角色</option>
                </select>
            </div>
            <div class="col-md-4">
                <select class="form-select" asp-for="IsWeakManaged">
                    <option value="">弱管理帳號</option>
                    <option value="true">是</option>
                    <option value="false">否</option>
                </select>
            </div>
        </div>
    </div>
    <input type="hidden" asp-for="PageSize" />
    <input type="hidden" name="PageNumber" value="1" />
</form>

<partial name="_FilterSummary" model="Model.FilterSummary" />

<form method="post" asp-page-handler="BatchDelete" class="bulk-toolbar" data-bulk-form data-confirm-message="確定刪除選中的使用者嗎？">
    <div class="bulk-toolbar-copy">
        <span class="bulk-toolbar-count" data-selected-count>0</span>
        <span>項已選擇</span>
    </div>
    <div class="bulk-toolbar-actions">
        <input type="hidden" asp-for="Keyword" />
        <input type="hidden" asp-for="IsActive" />
        <input type="hidden" asp-for="IsWeakManaged" />
        <input type="hidden" asp-for="RoleName" />
        <input type="hidden" asp-for="PageNumber" />
        <input type="hidden" asp-for="PageSize" />
        <button type="submit" class="btn btn-outline-danger" data-bulk-requires-selection>批量刪除</button>
    </div>
</form>

<div class="data-list-card">
    <div class="data-table-wrap">
        <table class="table table-sm table-striped align-middle data-table has-sticky-actions">
        <thead>
            <tr>
                <th class="checkbox-cell"><input class="form-check-input" type="checkbox" data-bulk-check-all /></th>
                <th>使用者名稱</th>
                <th>姓名</th>
                <th>信箱</th>
                <th>啟用</th>
                <th>角色</th>
                <th class="text-end">操作</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var user in Model.Users)
        {
            <tr>
                <td class="checkbox-cell"><input class="form-check-input" type="checkbox" value="@user.Id" data-bulk-checkbox /></td>
                <td>@user.UserName</td>
                <td>@user.DisplayName</td>
                <td>@user.Email</td>
                <td>@(user.IsActive ? "是" : "否")</td>
                <td>@string.Join("、", user.Roles.Select(RoleNames.GetDisplayName))</td>
                <td class="text-end text-nowrap">
                    <a class="btn btn-sm btn-outline-secondary" asp-page="./Edit" asp-route-id="@user.Id">編輯</a>
                    @if (Model.CanManagePassword)
                    {
                        <a class="btn btn-sm btn-outline-secondary" asp-page="./ResetPassword" asp-route-id="@user.Id">重設密碼</a>
                    }
                    <form method="post" asp-page-handler="Delete" asp-route-id="@user.Id" class="d-inline" onsubmit="return confirm('確定刪除該使用者嗎？');">
                        <button type="submit" class="btn btn-sm btn-outline-danger">刪除</button>
                    </form>
                </td>
            </tr>
        }
        @if (!Model.Users.Any())
        {
            <tr>
                <td colspan="7">
                    <div class="empty-state">暫無使用者資料</div>
                </td>
            </tr>
        }
        </tbody>
        </table>
    </div>
    <partial name="_Pagination" model="Model.Pagination" />
</div>
