@page
@model ProjectManager.Web.Pages.Admin.DataExchange.IndexModel
@{
    ViewData["Title"] = "資料匯入匯出";
}

<div class="page-header">
    <div>
        <h1 class="page-title">資料匯入匯出</h1>
        <div class="page-subtitle">管理員可透過 Excel 批量維護使用者、狀態、專案、請購、規劃中專案和保養訂單。</div>
    </div>
    <div class="page-actions">
        <form method="post" asp-page-handler="Export">
            <button class="btn btn-primary" type="submit" data-processing-label="正在準備匯出…">匯出目前資料</button>
        </form>
        <a class="btn btn-outline-secondary" asp-page="/Operations/Index">工作進度中心</a>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<div class="module-grid">
    <section class="module-card data-exchange-card">
        <div class="module-title">匯出 Excel</div>
        <div class="module-subtitle">匯出的活頁簿包含多個工作表，可直接作為批量匯入範本使用。</div>
        <div class="data-exchange-sheet-list">
            <span>Users</span>
            <span>ProjectStatuses</span>
            <span>Projects</span>
            <span>PurchaseRequests</span>
            <span>PlanningProjects</span>
            <span>MaintenanceOrders</span>
        </div>
        <form method="post" asp-page-handler="Export" class="mt-3">
            <button class="btn btn-outline-secondary" type="submit" data-processing-label="正在準備匯出…">建立匯出工作</button>
        </form>
    </section>

    <section class="module-card data-exchange-card">
        <div class="module-title">匯入 Excel</div>
        <div class="module-subtitle">依工作表名稱識別資料；已存在的資料會更新，不存在的資料會新增。</div>
        <form method="post" enctype="multipart/form-data" asp-page-handler="Import" class="data-exchange-form">
            <div class="mb-3">
                <label class="form-label" asp-for="UploadFile">Excel 檔案</label>
                <input class="form-control" asp-for="UploadFile" type="file" accept=".xlsx" />
                <span class="text-danger" asp-validation-for="UploadFile"></span>
            </div>
            <button class="btn btn-primary" type="submit" data-processing-label="正在建立匯入工作…">開始匯入</button>
        </form>
    </section>
</div>

<section class="detail-panel">
    <h2 class="detail-panel-title">匯入匹配規則</h2>
    <div class="data-table-wrap">
        <table class="table table-sm data-table">
            <thead>
                <tr>
                    <th>工作表</th>
                    <th>更新匹配欄位</th>
                    <th>說明</th>
                </tr>
            </thead>
            <tbody>
                <tr><td>Users</td><td>UserName</td><td>新增使用者的預設密碼取自 InitialPassword；為空時使用 ChangeMe123!</td></tr>
                <tr><td>ProjectStatuses</td><td>Code</td><td>專案狀態編碼保持唯一。</td></tr>
                <tr><td>Projects</td><td>Year + ProjectNumber</td><td>ProgressDescriptionHtml 可保留顏色標記。</td></tr>
                <tr><td>PurchaseRequests</td><td>Year + ProjectNumber + RequestNumber</td><td>必須先存在對應專案。</td></tr>
                <tr><td>PlanningProjects</td><td>Name</td><td>負責人可用使用者名稱、顯示名或信箱匹配。</td></tr>
                <tr><td>MaintenanceOrders</td><td>Year + CustomerName</td><td>執行人可用使用者名稱、顯示名稱或信箱匹配。</td></tr>
            </tbody>
        </table>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
