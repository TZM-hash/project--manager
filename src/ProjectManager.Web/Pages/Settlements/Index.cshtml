@page
@model ProjectManager.Web.Pages.Settlements.IndexModel
@{
    ViewData["Title"] = "月結";
}

<div class="page-header">
    <div>
        <h1 class="page-title">月結</h1>
        <div class="page-subtitle">查看歷史月結批次并进入列印或匯出流程</div>
    </div>
    <div class="page-actions">
        <a class="btn btn-primary" asp-page="./Create">新增月結</a>
    </div>
</div>

<form method="get" class="filter-panel advanced-filter-panel" data-filter-drawer>
    <div class="filter-quick-row">
        <div class="filter-quick-main">
            <input class="form-control" asp-for="Year" placeholder="年" />
            <input class="form-control" asp-for="Month" placeholder="月" />
        </div>
        <div class="filter-quick-actions">
            <button class="btn btn-outline-secondary" type="button" data-filter-drawer-toggle>進階篩選</button>
            <button class="btn btn-primary" type="submit">查詢</button>
        </div>
    </div>
    <div class="filter-drawer" data-filter-drawer-panel>
        <div class="filter-drawer-header">
            <div>
                <div class="filter-drawer-title">進階篩選</div>
                <div class="filter-drawer-subtitle">按批次号、建立人和備註定位月結批次</div>
            </div>
            <button class="btn btn-sm btn-outline-secondary" type="button" data-filter-drawer-close>收起</button>
        </div>
        <div class="row g-2">
            <div class="col-md-3"><input class="form-control" asp-for="BatchNumber" placeholder="批次号" /></div>
            <div class="col-md-4">
                <select class="form-select" asp-for="CreatedByUserId" asp-items="Model.CreatedByOptions">
                    <option value="">建立人</option>
                </select>
            </div>
            <div class="col-md-5"><input class="form-control" asp-for="Notes" placeholder="備註關鍵字" /></div>
        </div>
    </div>
    <input type="hidden" asp-for="PageSize" />
    <input type="hidden" name="PageNumber" value="1" />
</form>

<form method="get" class="filter-panel row g-2 d-none">
    <div class="col-md-2"><input class="form-control" asp-for="Year" placeholder="年" /></div>
    <div class="col-md-2"><input class="form-control" asp-for="Month" placeholder="月" /></div>
    <input type="hidden" asp-for="PageSize" />
    <div class="col-md-2"><button class="btn btn-outline-secondary w-100" type="submit">篩選</button></div>
</form>

<partial name="_FilterSummary" model="Model.FilterSummary" />

<div class="metric-grid dashboard-grid">
    @foreach (var metric in Model.Metrics)
    {
        <div class="metric-card metric-@metric.Accent">
            <div class="metric-label">@metric.Label</div>
            <div class="metric-value" data-countup>@metric.Value</div>
            <div class="metric-hint">@metric.Hint</div>
        </div>
    }
</div>

<div class="insight-grid insight-grid-single">
    <section class="chart-card">
        <div class="chart-title">年月批次數量</div>
        <div class="chart-subtitle">最近 6 个有月結批次的月份</div>
        <div class="mini-bars">
            @foreach (var slice in Model.MonthSlices)
            {
                <div class="mini-bar" style="--bar-height:@slice.Percent%;--bar-color:@slice.Color">
                    <span></span>
                    <strong>@slice.Value.ToString("0")</strong>
                    <small>@slice.Label</small>
                </div>
            }
        </div>
    </section>
</div>

@if (Model.IsAdministrator)
{
    <form method="post" asp-page-handler="BatchDelete" class="bulk-toolbar" data-bulk-form data-confirm-message="確定刪除選中的月結批次嗎？">
        <div class="bulk-toolbar-copy">
            <span class="bulk-toolbar-count" data-selected-count>0</span>
            <span>个批次已選擇</span>
        </div>
        <div class="bulk-toolbar-actions">
            <input type="hidden" asp-for="Year" />
            <input type="hidden" asp-for="Month" />
            <input type="hidden" asp-for="BatchNumber" />
            <input type="hidden" asp-for="CreatedByUserId" />
            <input type="hidden" asp-for="Notes" />
            <input type="hidden" asp-for="PageNumber" />
            <input type="hidden" asp-for="PageSize" />
            <button type="submit" class="btn btn-outline-danger" data-bulk-requires-selection>批量刪除</button>
        </div>
    </form>
}

<div class="data-list-card">
    <div class="data-table-wrap">
        <table class="table table-sm table-striped align-middle data-table has-sticky-actions">
        <thead>
            <tr>
                @if (Model.IsAdministrator)
                {
                    <th class="checkbox-cell"><input class="form-check-input" type="checkbox" data-bulk-check-all /></th>
                }
                <th>年</th>
                <th>月</th>
                <th>批次</th>
                <th class="numeric">專案数</th>
                <th>建立人</th>
                <th>建立時間</th>
                <th>備註</th>
                <th class="text-end">操作</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var batch in Model.Batches)
        {
            <tr>
                @if (Model.IsAdministrator)
                {
                    <td class="checkbox-cell"><input class="form-check-input" type="checkbox" value="@batch.Id" data-bulk-checkbox /></td>
                }
                <td>@batch.Year</td>
                <td>@batch.Month</td>
                <td>@batch.BatchNumber</td>
                <td class="numeric">@batch.Items.Count</td>
                <td>@(batch.CreatedByUser?.DisplayName ?? batch.CreatedByUser?.UserName)</td>
                <td>@batch.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                <td>@batch.Notes</td>
                <td class="text-end text-nowrap">
                    <a class="btn btn-sm btn-outline-secondary" asp-page="./Details" asp-route-id="@batch.Id">明細</a>
                    <a class="btn btn-sm btn-outline-secondary" asp-page="./Print" asp-route-id="@batch.Id">列印</a>
                    @if (Model.IsAdministrator)
                    {
                        <form method="post" asp-page-handler="Delete" asp-route-id="@batch.Id" asp-route-Year="@Model.Year" asp-route-Month="@Model.Month" asp-route-BatchNumber="@Model.BatchNumber" asp-route-CreatedByUserId="@Model.CreatedByUserId" asp-route-Notes="@Model.Notes" asp-route-PageNumber="@Model.PageNumber" asp-route-PageSize="@Model.PageSize" class="d-inline" onsubmit="return confirm('確定刪除該月結批次嗎？');">
                            <button type="submit" class="btn btn-sm btn-outline-danger">刪除</button>
                        </form>
                    }
                </td>
            </tr>
        }
        @if (!Model.Batches.Any())
        {
            <tr>
                <td colspan="@(Model.IsAdministrator ? 9 : 8)">
                    <partial name="_EmptyState" model='new ProjectManager.Web.Pages.Shared.EmptyStateViewModel(
                        "目前沒有月結批次",
                        "可以建立新的月結批次，或清除篩選後查看其他月份。",
                        "inbox",
                        "新增月結批次",
                        "/Settlements/Create",
                        ClearActionText: "清除篩選",
                        ClearActionPage: "/Settlements/Index")' />
                </td>
            </tr>
        }
        </tbody>
        </table>
    </div>
    <partial name="_Pagination" model="Model.Pagination" />
</div>
