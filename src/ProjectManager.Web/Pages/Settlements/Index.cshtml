@page
@model ProjectManager.Web.Pages.Settlements.IndexModel
@{
    ViewData["Title"] = "月结";
}

<div class="page-header">
    <div>
        <h1 class="page-title">月结</h1>
        <div class="page-subtitle">查看历史月结批次并进入打印或导出流程</div>
    </div>
    <div class="page-actions">
        <a class="btn btn-primary" asp-page="./Create">新增月结</a>
    </div>
</div>

<form method="get" class="filter-panel row g-2">
    <div class="col-md-2"><input class="form-control" asp-for="Year" placeholder="年" /></div>
    <div class="col-md-2"><input class="form-control" asp-for="Month" placeholder="月" /></div>
    <div class="col-md-2"><button class="btn btn-outline-secondary w-100" type="submit">筛选</button></div>
</form>

<div class="data-table-wrap">
    <table class="table table-sm table-striped align-middle data-table">
        <thead>
            <tr>
                <th>年</th>
                <th>月</th>
                <th>批次</th>
                <th class="numeric">项目数</th>
                <th>创建人</th>
                <th>创建时间</th>
                <th>备注</th>
                <th class="text-end">操作</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var batch in Model.Batches)
        {
            <tr>
                <td>@batch.Year</td>
                <td>@batch.Month</td>
                <td>@batch.BatchNumber</td>
                <td class="numeric">@batch.Items.Count</td>
                <td>@(batch.CreatedByUser?.DisplayName ?? batch.CreatedByUser?.UserName)</td>
                <td>@batch.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                <td>@batch.Notes</td>
                <td class="text-end text-nowrap">
                    <a class="btn btn-sm btn-outline-secondary" asp-page="./Details" asp-route-id="@batch.Id">详情</a>
                    <a class="btn btn-sm btn-outline-secondary" asp-page="./Print" asp-route-id="@batch.Id">打印</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
