@model ProjectManager.Web.Models.MonthlySettlementBatch

<div class="data-table-wrap">
    <table class="table table-sm table-striped align-middle settlement-table data-table">
        <thead>
            <tr>
                <th>母案案號</th>
                <th>專案工號</th>
                <th>專案名稱</th>
                <th>專案人員</th>
                <th class="numeric">進度</th>
                <th class="numeric">金額</th>
                <th class="numeric">收款比例</th>
                <th>狀態</th>
                <th>結案日期</th>
                <th>請購號彙總</th>
                <th class="numeric">请购金額</th>
                <th>子案對接人員</th>
                <th>付款比例</th>
                <th class="numeric">實際已付款</th>
                <th>進度說明</th>
                <th>更新人员</th>
                <th>来源更新時間</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model.Items.OrderBy(x => x.ProjectNumber))
        {
            <tr>
                <td>@item.ParentCaseNumber</td>
                <td>@item.ProjectNumber</td>
                <td>@item.ProjectName</td>
                <td>@item.ProjectPersonnelText</td>
                <td class="numeric"><partial name="_PercentBar" model="new ProjectManager.Web.Pages.Shared.PercentBarModel(item.ProgressPercent)" /></td>
                <td class="numeric">@item.ProjectAmount.ToString("N2")</td>
                <td class="numeric"><partial name="_PercentBar" model="new ProjectManager.Web.Pages.Shared.PercentBarModel(item.CollectionPercent)" /></td>
                <td>@item.StatusName</td>
                <td>@item.ClosedYearMonth?.ToString("yyyy-MM")</td>
                <td>@item.PurchaseRequestSummary</td>
                <td class="numeric">@item.PurchaseAmountTotal.ToString("N2")</td>
                <td>@item.SubCaseContactSummary</td>
                <td>@item.PaymentPercentSummary</td>
                <td class="numeric">@item.ActualPaidAmountTotal.ToString("N2")</td>
                <td>@item.ProgressDescription</td>
                <td>@item.UpdatedByUserName</td>
                <td>@item.SourceUpdatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
            </tr>
        }
        </tbody>
    </table>
</div>
