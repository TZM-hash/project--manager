@page
@model ProjectManager.Web.Pages.Settlements.CreateModel
@{
    ViewData["Title"] = "新增月结";
}

<div class="page-header">
    <div>
        <h1 class="page-title">新增月结</h1>
        <div class="page-subtitle">生成指定年月的项目快照批次</div>
    </div>
</div>

<form method="post" class="form-section row g-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="col-md-2">
        <label class="form-label">年</label>
        <input class="form-control" asp-for="Input.Year" />
    </div>
    <div class="col-md-2">
        <label class="form-label">月</label>
        <input class="form-control" asp-for="Input.Month" />
    </div>
    <div class="col-md-6">
        <label class="form-label">备注</label>
        <input class="form-control" asp-for="Input.Notes" />
    </div>
    <div class="col-md-2 d-flex align-items-end">
        <button class="btn btn-primary w-100" type="submit">生成月结</button>
    </div>
</form>

<section class="detail-panel">
    <h2 class="detail-panel-title">当前项目预览</h2>
    <div class="data-table-wrap">
        <table class="table table-sm table-striped align-middle data-table">
            <thead>
                <tr>
                    <th>年</th>
                    <th>母案案号</th>
                    <th>项目工号</th>
                    <th>项目名称</th>
                    <th>专案人员</th>
                    <th class="numeric">进度</th>
                    <th class="numeric">金额</th>
                    <th>状态</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var project in Model.PreviewProjects)
            {
                <tr>
                    <td>@project.Year</td>
                    <td>@project.ParentCaseNumber</td>
                    <td>@project.ProjectNumber</td>
                    <td>@project.Name</td>
                    <td>@string.Join("；", project.Assignments.Select(x => x.User?.DisplayName ?? x.User?.UserName ?? x.UserId))</td>
                    <td class="numeric">@project.ProgressPercent.ToString("0.##")%</td>
                    <td class="numeric">@project.ProjectAmount.ToString("N2")</td>
                    <td><partial name="_StatusBadge" model="project.Status" /></td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
