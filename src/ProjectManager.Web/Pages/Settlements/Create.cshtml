@page
@model ProjectManager.Web.Pages.Settlements.CreateModel
@{
    ViewData["Title"] = "新增月结";
}

<h1 class="h3">新增月结</h1>

<form method="post" class="row g-3 mt-1 mb-4">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="col-md-2">
        <label class="form-label">年</label>
        <input class="form-control" asp-for="Input.Year" />
    </div>
    <div class="col-md-2">
        <label class="form-label">月</label>
        <input class="form-control" asp-for="Input.Month" />
    </div>
    <div class="col-md-6">
        <label class="form-label">备注</label>
        <input class="form-control" asp-for="Input.Notes" />
    </div>
    <div class="col-md-2 d-flex align-items-end">
        <button class="btn btn-primary w-100" type="submit">生成月结</button>
    </div>
</form>

<h2 class="h5">当前项目预览</h2>
<table class="table table-sm table-striped align-middle">
    <thead>
        <tr>
            <th>年</th>
            <th>母案案号</th>
            <th>项目工号</th>
            <th>项目名称</th>
            <th>专案人员</th>
            <th>进度</th>
            <th>金额</th>
            <th>状态</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var project in Model.PreviewProjects)
    {
        <tr>
            <td>@project.Year</td>
            <td>@project.ParentCaseNumber</td>
            <td>@project.ProjectNumber</td>
            <td>@project.Name</td>
            <td>@string.Join("；", project.Assignments.Select(x => x.User?.DisplayName ?? x.User?.UserName ?? x.UserId))</td>
            <td>@project.ProgressPercent.ToString("0.##")%</td>
            <td>@project.ProjectAmount.ToString("N2")</td>
            <td>@project.Status?.Name</td>
        </tr>
    }
    </tbody>
</table>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
