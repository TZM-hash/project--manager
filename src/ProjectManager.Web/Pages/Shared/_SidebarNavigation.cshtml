@using ProjectManager.Web.Security
@{
    var isAdministrator = User.IsSystemAdministrator();
    var canManageBusinessData = User.CanManageAllBusinessData();
    var canViewReports = User.IsRegularUser();
    var canUseSettlements = canManageBusinessData;
}

<section class="nav-section" aria-labelledby="nav-work-label">
    <div class="nav-section-label" id="nav-work-label">業務工作</div>
    <ul class="nav flex-column">
        <li class="nav-item">
            <a class="nav-link" asp-area="" asp-page="/Index" data-nav-label="首頁">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 10.5 12 3l9 7.5"/><path d="M5 9.5V20a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V9.5"/><path d="M9.5 21v-6h5v6"/></svg>
                <span>首頁</span>
            </a>
        </li>
        @if (canManageBusinessData)
        {
            <li class="nav-item">
                <a class="nav-link" asp-area="" asp-page="/Admin/ProjectAssignments/Index" data-nav-label="專案分配">
                    <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 20V10"/><path d="M4 20l5-6 4 4 7-10"/><circle cx="4" cy="10" r="1.5"/></svg>
                    <span>專案分配</span>
                </a>
            </li>
        }
        @if (canManageBusinessData)
        {
            <li class="nav-item">
                <a class="nav-link" asp-area="" asp-page="/Admin/Projects/Index" data-nav-label="專案總覽">
                    <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 7.5A1.5 1.5 0 0 1 4.5 6H9l2 2.5h8.5A1.5 1.5 0 0 1 21 10v7.5A1.5 1.5 0 0 1 19.5 19h-15A1.5 1.5 0 0 1 3 17.5Z"/></svg>
                    <span>專案總覽</span>
                </a>
            </li>
        }
        <li class="nav-item">
            <a class="nav-link" asp-area="" asp-page="/Workbench/Projects/Index" data-nav-label="我的專案">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="7" height="16" rx="1.5"/><rect x="14" y="4" width="7" height="10" rx="1.5"/></svg>
                <span>我的專案</span>
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" asp-area="" asp-page="/Workbench/PlanningProjects/Index" data-nav-label="規劃中專案">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3.5" y="4.5" width="17" height="16" rx="2"/><path d="M3.5 9h17"/><path d="M8 3v3M16 3v3"/><path d="M7.5 13h4M7.5 16.5h7"/></svg>
                <span>規劃中專案</span>
            </a>
        </li>
        @if (canManageBusinessData)
        {
            <li class="nav-item">
                <a class="nav-link" asp-area="" asp-page="/Admin/MaintenanceOrders/Index" data-nav-label="保養訂單">
                    <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14.7 6.3a4 4 0 0 0-5.4 5.3L4 17l3 3 5.4-5.3a4 4 0 0 0 5.3-5.4l-2.7 2.7-2.3-.4-.4-2.3Z"/></svg>
                    <span>保養訂單</span>
                </a>
            </li>
        }
        @if (User.Identity?.IsAuthenticated == true)
        {
            <li class="nav-item">
                <a class="nav-link" asp-area="" asp-page="/Operations/Index" data-nav-label="工作進度中心">
                    <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
                    <span>工作進度中心</span>
                </a>
            </li>
        }
        @if (canUseSettlements)
        {
            <li class="nav-item">
                <a class="nav-link" asp-area="" asp-page="/Settlements/Index" data-nav-label="月結">
                    <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 3h12v18l-3-1.8L12 21l-3-1.8L6 21Z"/><path d="M9.5 8.5h5M9.5 12h5"/></svg>
                    <span>月結</span>
                </a>
            </li>
        }
    </ul>
</section>

@if (canViewReports || canManageBusinessData)
{
    <section class="nav-section" aria-labelledby="nav-report-label">
        <div class="nav-section-label" id="nav-report-label">報表分析</div>
        <ul class="nav flex-column">
            @if (canViewReports)
            {
                <li class="nav-item">
                    <a class="nav-link" asp-area="" asp-page="/Reports/OpenProjects/Index" data-nav-label="未結案報表">
                        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 20V4"/><path d="M4 20h16"/><rect x="7" y="11" width="3" height="6" rx="0.8"/><rect x="12.5" y="7" width="3" height="10" rx="0.8"/><rect x="18" y="13" width="3" height="4" rx="0.8"/></svg>
                        <span>未結案報表</span>
                    </a>
                </li>
            }
            @if (canManageBusinessData)
            {
                <li class="nav-item">
                    <a class="nav-link" asp-area="" asp-page="/Admin/Archives/Index" data-nav-label="歸檔歷史">
                        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 8V5a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v3"/><path d="M3 8l9 6 9-6"/><path d="M3 8v11a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V8"/></svg>
                        <span>歸檔歷史</span>
                    </a>
                </li>
            }
        </ul>
    </section>
}

@if (canManageBusinessData)
{
    <section class="nav-section" aria-labelledby="nav-system-label">
        <div class="nav-section-label" id="nav-system-label">系統管理</div>
        <ul class="nav flex-column">
            @if (isAdministrator)
            {
                <li class="nav-item"><a class="nav-link" asp-area="" asp-page="/Admin/Users/Index" data-nav-label="使用者管理"><svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="9" cy="8" r="3"/><path d="M3 20v-1.5A4.5 4.5 0 0 1 7.5 14h3A4.5 4.5 0 0 1 15 18.5V20"/><path d="M16 6h5M18.5 3.5v5"/></svg><span>使用者管理</span></a></li>
            }
            <li class="nav-item"><a class="nav-link" asp-area="" asp-page="/Admin/Vendors/Index" data-nav-label="廠商管理"><svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/></svg><span>廠商管理</span></a></li>
            <li class="nav-item"><a class="nav-link" asp-area="" asp-page="/Admin/Statuses/Index" data-nav-label="狀態設定"><svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M3 12V5a2 2 0 0 1 2-2h7l9 9-9 9-9-9Z"/><circle cx="8" cy="8" r="1.4"/></svg><span>狀態設定</span></a></li>
            <li class="nav-item"><a class="nav-link" asp-area="" asp-page="/Admin/DataExchange/Index" data-nav-label="資料匯入匯出"><svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 8h13"/><path d="m13 4 4 4-4 4"/><path d="M20 16H7"/><path d="m11 12-4 4 4 4"/></svg><span>資料匯入匯出</span></a></li>
            @if (isAdministrator)
            {
                <li class="nav-item"><a class="nav-link" asp-area="" asp-page="/Admin/Operations/Index" data-nav-label="運維監控"><svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 19V9M10 19V5M16 19v-7M22 19V3"/></svg><span>運維監控</span></a></li>
                <li class="nav-item"><a class="nav-link" asp-area="" asp-page="/Admin/Settings/Index" data-nav-label="系統設定"><svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="3.5"/><path d="M12 2v3M12 19v3M2 12h3M19 12h3M4.9 4.9 7 7M17 17l2.1 2.1M19.1 4.9 17 7M7 17l-2.1 2.1"/></svg><span>系統設定</span></a></li>
            }
        </ul>
    </section>
}
