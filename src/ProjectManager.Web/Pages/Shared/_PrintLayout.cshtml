<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - 台塑電子專案管理系統</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        body {
            background: #fff;
        }
        .print-report {
            max-width: 800px;
            margin: 0 auto;
            padding: 2rem;
        }
        .print-header {
            text-align: center;
            margin-bottom: 2rem;
        }
        .print-header h1 {
            font-size: 1.6rem;
            font-weight: 800;
            margin-bottom: 0.5rem;
        }
        .print-date {
            color: #64748b;
            font-size: 0.9rem;
        }
        .print-section-title {
            margin-top: 2rem;
            margin-bottom: 1rem;
            font-size: 1.2rem;
            font-weight: 700;
        }
        .print-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 1rem;
        }
        .print-table th,
        .print-table td {
            border: 1px solid #999;
            padding: 0.5rem 0.75rem;
            font-size: 0.9rem;
        }
        .print-table th {
            background: #f1f5f9;
            text-align: left;
            white-space: nowrap;
            width: 8rem;
        }
        .print-table-list th {
            background: #e2e8f0;
            text-align: center;
            width: auto;
        }
        .print-table-list td {
            vertical-align: top;
        }
        @@media print {
            .no-print {
                display: none !important;
            }
        }
        .print-back-btn {
            margin-bottom: 1rem;
        }
    </style>
</head>
<body>
    <div class="no-print print-back-btn">
        <a href="javascript:history.back()" class="btn btn-outline-secondary btn-sm">返回</a>
    </div>
    @RenderBody()
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
