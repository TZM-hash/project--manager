@using ProjectManager.Web.Security
@using ProjectManager.Web.Extensions
@inject ProjectManager.Web.Services.SystemSettingsService SystemSettingsService
@{
    var visualTheme = await SystemSettingsService.GetVisualThemeAsync(Context.RequestAborted);
    var themeClass = ProjectManager.Web.Services.SystemSettingsService.ToThemeCssClass(visualTheme);
    var motionStyle = await SystemSettingsService.GetMotionStyleAsync(Context.RequestAborted);
    var motionStyleClass = ProjectManager.Web.Services.SystemSettingsService.ToMotionCssClass(motionStyle);
    var uiEffectsLevel = await SystemSettingsService.GetUiEffectsLevelAsync(Context.RequestAborted);
    var uiEffectsClass = ProjectManager.Web.Services.SystemSettingsService.ToCssClass(uiEffectsLevel);
    var displayLanguage = await SystemSettingsService.GetDisplayLanguageAsync(Context.RequestAborted);
    var languageClass = ProjectManager.Web.Services.SystemSettingsService.ToLanguageClass(displayLanguage);
    var globalFont = await SystemSettingsService.GetGlobalFontAsync(Context.RequestAborted);
    var fontClass = ProjectManager.Web.Services.SystemSettingsService.ToFontCssClass(globalFont);
    var htmlLanguage = displayLanguage == ProjectManager.Web.Services.SystemSettingsService.DisplayLanguage.SimplifiedChinese
        ? "zh-CN"
        : "zh-TW";
}
<!DOCTYPE html>
<html lang="@htmlLanguage">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - 台塑電子專案管理系統</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/base.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/themes.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ProjectManager.Web.styles.css" asp-append-version="true" />
</head>
<body class="app-shell @themeClass @motionStyleClass @uiEffectsClass @languageClass @fontClass">
    <div class="app-bg-fx" aria-hidden="true">
        <span class="app-bg-orb app-bg-orb-1"></span>
        <span class="app-bg-orb app-bg-orb-2"></span>
        <span class="app-bg-orb app-bg-orb-3"></span>
    </div>
    <aside class="app-sidebar">
        <div class="app-sidebar-brand">
            <a asp-area="" asp-page="/Index">
                <span class="app-brand-mark">
                    <img src="~/img/logo.png" asp-append-version="true" alt="台塑電子專案管理系統 LOGO" />
                </span>
                <span>台塑電子專案管理系統</span>
            </a>
        </div>
        <nav class="app-sidebar-nav" aria-label="主要導覽">
            <partial name="_SidebarNavigation" />
        </nav>
    </aside>
    <div class="app-content">
        <header class="app-header">
            <div class="app-header-content">
                <button class="app-sidebar-toggle" type="button" data-sidebar-toggle
                        aria-label="收合側邊導覽" aria-expanded="true">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="app-header-title">
                    <span>@ViewData["Title"]</span>
                </div>
                <partial name="_LoginPartial" />
            </div>
        </header>
        <main role="main" class="app-main">
            <partial name="_FlashMessages" />
            @RenderBody()
        </main>
        <footer class="footer app-footer text-muted">
            &copy; 2026 - 台塑電子專案管理系統
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script type="module" src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
