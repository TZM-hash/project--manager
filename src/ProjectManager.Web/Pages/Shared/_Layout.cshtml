@using ProjectManager.Web.Security
@using ProjectManager.Web.Extensions
<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - 台塑电子项目管理系统</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ProjectManager.Web.styles.css" asp-append-version="true" />
</head>
<body class="app-shell">
    <div class="app-bg-fx" aria-hidden="true">
        <span class="app-bg-orb app-bg-orb-1"></span>
        <span class="app-bg-orb app-bg-orb-2"></span>
        <span class="app-bg-orb app-bg-orb-3"></span>
    </div>
    <aside class="app-sidebar">
        <div class="app-sidebar-brand">
            <a asp-area="" asp-page="/Index">
                <span class="app-brand-mark">
                    <img src="~/img/logo.png" asp-append-version="true" alt="台塑电子项目管理系统 LOGO" />
                </span>
                <span>台塑电子项目管理系统</span>
            </a>
        </div>
        <nav class="app-sidebar-nav">
            <ul class="nav flex-column">
                <li class="nav-item">
                    <a class="nav-link" asp-area="" asp-page="/Index">
                        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 10.5 12 3l9 7.5"/><path d="M5 9.5V20a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V9.5"/><path d="M9.5 21v-6h5v6"/></svg>
                        <span>首页</span>
                    </a>
                </li>
                @if (User.IsInRole(RoleNames.Administrator))
                {
                    <li class="nav-item nav-group">
                        <a class="nav-link nav-group-toggle" href="javascript:void(0)" onclick="toggleNavGroup(this)">
                            <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 7h11"/><path d="M18 7h2"/><circle cx="16.5" cy="7" r="2"/><path d="M4 17h2"/><path d="M9 17h11"/><circle cx="7.5" cy="17" r="2"/></svg>
                            <span>基础设定</span>
                        </a>
                        <ul class="nav nav-group-items">
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-page="/Admin/Users/Index">
                                    <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 20v-1.5a3.5 3.5 0 0 0-3.5-3.5h-5A3.5 3.5 0 0 0 4 18.5V20"/><circle cx="10" cy="8" r="3.2"/><path d="M20 20v-1.5a3.5 3.5 0 0 0-2.7-3.4"/><path d="M15.5 5.2a3.2 3.2 0 0 1 0 5.6"/></svg>
                                    <span>用户管理</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-page="/Admin/Statuses/Index">
                                    <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 12V5a2 2 0 0 1 2-2h7l9 9-9 9-9-9Z"/><circle cx="8" cy="8" r="1.4"/></svg>
                                    <span>状态设置</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-page="/Admin/DataExchange/Index">
                                    <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 8h13"/><path d="m13 4 4 4-4 4"/><path d="M20 16H7"/><path d="m11 12-4 4 4 4"/></svg>
                                    <span>数据导入导出</span>
                                </a>
                            </li>
                        </ul>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-page="/Admin/Projects/Index">
                            <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 7.5A1.5 1.5 0 0 1 4.5 6H9l2 2.5h8.5A1.5 1.5 0 0 1 21 10v7.5A1.5 1.5 0 0 1 19.5 19h-15A1.5 1.5 0 0 1 3 17.5Z"/></svg>
                            <span>项目管理</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-page="/Admin/MaintenanceOrders/Index">
                            <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14.7 6.3a4 4 0 0 0-5.4 5.3L4 17l3 3 5.4-5.3a4 4 0 0 0 5.3-5.4l-2.7 2.7-2.3-.4-.4-2.3Z"/></svg>
                            <span>保养订单</span>
                        </a>
                    </li>
                }
                @if (User.IsInRole(RoleNames.Administrator) || User.IsInRole(RoleNames.ProjectStaff) || User.IsInRole(RoleNames.Leader) || User.IsInRole(RoleNames.Viewer))
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-page="/Workbench/Projects/Index">
                            <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="7" height="16" rx="1.5"/><rect x="14" y="4" width="7" height="10" rx="1.5"/></svg>
                            <span>专案管理</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-page="/Workbench/PlanningProjects/Index">
                            <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3.5" y="4.5" width="17" height="16" rx="2"/><path d="M3.5 9h17"/><path d="M8 3v3M16 3v3"/><path d="M7.5 13h4M7.5 16.5h7"/></svg>
                            <span>规划中专案</span>
                        </a>
                    </li>
                }
                @if (User.IsInRole(RoleNames.Administrator) || User.IsInRole(RoleNames.Leader))
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-page="/Settlements/Index">
                            <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 3h12v18l-3-1.8L12 21l-3-1.8L6 21Z"/><path d="M9.5 8.5h5M9.5 12h5"/></svg>
                            <span>月结</span>
                        </a>
                    </li>
                }
                @if (User.IsInRole(RoleNames.Administrator) || User.IsInRole(RoleNames.Leader) || User.IsInRole(RoleNames.Viewer))
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-page="/Reports/OpenProjects/Index">
                            <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 20V4"/><path d="M4 20h16"/><rect x="7" y="11" width="3" height="6" rx="0.8"/><rect x="12.5" y="7" width="3" height="10" rx="0.8"/><rect x="18" y="13" width="3" height="4" rx="0.8"/></svg>
                            <span>报表</span>
                        </a>
                    </li>
                }
            </ul>
        </nav>
    </aside>
    <div class="app-content">
        <header class="app-header">
            <div class="app-header-content">
                <button class="app-sidebar-toggle" type="button" onclick="toggleSidebar()">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="app-header-title">
                    <span>@ViewData["Title"]</span>
                </div>
                <partial name="_LoginPartial" />
            </div>
        </header>
        <main role="main" class="app-main">
            @RenderBody()
        </main>
        <footer class="footer app-footer text-muted">
            &copy; 2026 - 台塑电子项目管理系统
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
