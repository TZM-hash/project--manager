@model ProjectManager.Web.Pages.Shared.ProjectGanttPanelModel
@using ProjectManager.Web.Services
@{
    var input = Model.Input;
    while (input.Tasks.Count < 3)
    {
        input.Tasks.Add(new ProjectGanttTaskInputModel());
    }

    var archiveDemand = ProjectGanttService.BuildArchiveDemandInfo(Model.Project, Model.ArchiveDate);
    var today = DateOnly.FromDateTime(DateTime.UtcNow);
    var ownerNames = Model.Project.Assignments.ToDictionary(
        assignment => assignment.UserId,
        assignment => assignment.User?.DisplayName ?? assignment.User?.UserName ?? assignment.UserId);
    var months = ProjectGanttService.BuildMonths(input, archiveDemand.Date);
    var archiveLinePosition = ProjectGanttService.GetTimelinePositionPercent(archiveDemand.Date, months);
    var scaleText = ProjectGanttService.GetTimelineScaleText(months);
    var taskRows = input.Tasks
        .Select((task, index) => (Task: task, Index: index))
        .Where(x => !string.IsNullOrWhiteSpace(x.Task.Name) || x.Task.PlannedStartDate is not null || x.Task.PlannedFinishDate is not null || x.Task.ActualStartDate is not null || x.Task.ActualFinishDate is not null || x.Task.ProgressPercent > 0 || x.Task.IsMilestone || !string.IsNullOrWhiteSpace(x.Task.OwnerUserId) || !string.IsNullOrWhiteSpace(x.Task.ProgressDescription))
        .ToList();
    var progressPoints = ProjectGanttService.BuildProgressLinePoints(
        taskRows.Select(x => x.Task).ToList(),
        archiveDemand.Date,
        months);
}

<section class="detail-panel gantt-panel" data-gantt-editor>
    <div class="gantt-panel-head">
        <div>
            <h2 class="detail-panel-title">甘特圖</h2>
            <div class="chart-subtitle">黑框為完整計劃工期，進度條按百分比分段顯色，實色為已完成部分、同色淡色為未完成部分；狀態徽章另行提示風險、等待與阻塞。目前時間單位：@scaleText。</div>
        </div>
        <div class="page-actions">
            <a class="btn btn-outline-secondary" asp-page="/Workbench/Projects/GanttPrint" asp-route-id="@Model.Project.Id">預覽 / 列印</a>
            <a class="btn btn-outline-secondary" asp-page-handler="ExportGantt" asp-route-id="@Model.Project.Id">匯出 Excel</a>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Message))
    {
        <div class="alert alert-success">@Model.Message</div>
    }

    @if (Model.Errors.Count > 0)
    {
        <div class="alert alert-danger">
            @foreach (var error in Model.Errors)
            {
                <div>@error</div>
            }
            @if (Model.Errors.Any(error => error.Contains("其他使用者更新", StringComparison.Ordinal)))
            {
                <a asp-route-id="@Model.Project.Id" asp-route-Tab="gantt">重新載入最新版本</a>
            }
        </div>
    }

    <div class="gantt-auto-grid">
        <div class="gantt-auto-item"><span>專案名稱</span><strong data-language-preserve translate="no">@Model.Project.Name</strong></div>
        <div class="gantt-auto-item"><span>專案工號</span><strong data-language-preserve translate="no">@Model.Project.ProjectNumber</strong></div>
        <div class="gantt-auto-item"><span>母案案號</span><strong data-language-preserve translate="no">@Model.Project.ParentCaseNumber</strong></div>
        <div class="gantt-auto-item"><span>年度</span><strong>@Model.Project.Year</strong></div>
        <div class="gantt-auto-item"><span>目前狀態</span><strong>@Model.Project.Status?.Name</strong></div>
        <div class="gantt-auto-item"><span>負責人</span><strong data-language-preserve translate="no">@string.Join("; ", Model.Project.Assignments.Select(x => x.User?.DisplayName ?? x.User?.UserName ?? x.UserId))</strong></div>
        <div class="gantt-auto-item gantt-auto-item-redline"><span>全局檔案日期</span><strong>@archiveDemand.Date.ToString("yyyy/M/d")</strong></div>
        <div class="gantt-auto-item gantt-auto-item-redline"><span>進度線負責人</span><strong data-language-preserve translate="no">@archiveDemand.Person</strong></div>
    </div>

    <form method="post" asp-page-handler="SaveGantt" asp-route-id="@Model.Project.Id" class="gantt-form">
        <input type="hidden" name="GanttInput.RowVersion" value="@input.RowVersion" />
        <div class="gantt-plan-grid">
            <div>
                <label class="form-label">整體開始日</label>
                <input class="form-control" asp-for="Input.StartDate" type="date" name="GanttInput.StartDate" />
            </div>
            <div>
                <label class="form-label">整體完成日</label>
                <input class="form-control" asp-for="Input.FinishDate" type="date" name="GanttInput.FinishDate" />
            </div>
            <div class="gantt-plan-note">
                <label class="form-label">進度說明</label>
                <textarea class="form-control" asp-for="Input.ProgressNote" name="GanttInput.ProgressNote" rows="3"></textarea>
            </div>
        </div>

        <div class="gantt-visual-legend" aria-label="甘特圖顯示圖例">
            <div class="gantt-progress-legend">
                <span><i class="gantt-legend-bar"><b></b></i>實色：已完成</span>
                <span><i class="gantt-legend-bar gantt-legend-bar-pale"><b></b></i>淡色：未完成</span>
                <span class="gantt-progress-start"><i class="gantt-legend-progress-dot"></i>0–19%</span>
                <span class="gantt-progress-low"><i class="gantt-legend-progress-dot"></i>20–49%</span>
                <span class="gantt-progress-mid"><i class="gantt-legend-progress-dot"></i>50–79%</span>
                <span class="gantt-progress-high"><i class="gantt-legend-progress-dot"></i>80–99%</span>
                <span class="gantt-progress-complete"><i class="gantt-legend-progress-dot"></i>100%</span>
                <span><i class="gantt-legend-redline"></i>檔案日期</span>
                <span><i class="gantt-legend-milestone"></i>里程碑</span>
            </div>
            <div class="gantt-status-legend">
                <span class="gantt-task-state-completed"><i></i>已完成</span>
                <span class="gantt-task-state-in-progress"><i></i>進行中</span>
                <span class="gantt-task-state-ahead"><i></i>進度超前</span>
                <span class="gantt-task-state-at-risk"><i></i>有風險</span>
                <span class="gantt-task-state-waiting"><i></i>等待中</span>
                <span class="gantt-task-state-blocked"><i></i>阻塞</span>
                <span class="gantt-task-state-not-started"><i></i>未開始</span>
            </div>
        </div>

        <div class="gantt-chart-wrap" aria-label="專案甘特圖時間軸：黑框顯示計劃工期，實色顯示完成進度，淡色顯示剩餘進度" style="--month-count:@months.Count;--task-count:@taskRows.Count">
            <div class="gantt-chart-header">
                <span class="gantt-chart-header-label">工作項目</span>
                <div class="gantt-chart-months">
                    @foreach (var month in months)
                    {
                        <span>@month.Label</span>
                    }
                </div>
                <span class="gantt-chart-header-percent">進度</span>
            </div>
            <div class="gantt-chart-body">
                @if (taskRows.Count == 0)
                {
                    <div class="empty-state">暫無細分工作，儲存後會產生甘特時間軸。</div>
                }
                @for (var progressIndex = 0; progressIndex < taskRows.Count; progressIndex++)
                {
                    var row = taskRows[progressIndex];
                    var bar = ProjectGanttService.BuildBar(row.Task, months);
                    var point = progressPoints[progressIndex];
                    var visualState = ProjectGanttService.GetTaskVisualState(row.Task, archiveDemand.Date, point.State);
                    var visualStateLabel = ProjectGanttService.GetTaskVisualStateLabel(visualState);
                    var visualStateClass = ProjectGanttService.GetTaskVisualStateCssClass(visualState);
                    var progressStageClass = bar.ProgressPercent >= 100 ? "gantt-progress-complete"
                        : bar.ProgressPercent >= 80 ? "gantt-progress-high"
                        : bar.ProgressPercent >= 50 ? "gantt-progress-mid"
                        : bar.ProgressPercent >= 20 ? "gantt-progress-low"
                        : "gantt-progress-start";
                    var progressText = $"{bar.ProgressPercent:0.##}%";
                    var progressPosition = bar.LeftPercent + (bar.WidthPercent * Math.Clamp(bar.ProgressPercent, 0m, 100m) / 100m);
                    var progressTooltip = ProjectGanttService.GetProgressSummary(point);
                    var ownerName = !string.IsNullOrWhiteSpace(row.Task.OwnerUserId) && ownerNames.TryGetValue(row.Task.OwnerUserId, out var displayName) ? displayName : "未指派";
                    var predecessorName = row.Task.PredecessorTaskId is { } predecessorId
                        ? input.Tasks.FirstOrDefault(task => task.Id == predecessorId)?.Name
                        : null;
                    var overdue = ProjectGanttService.IsTaskOverdue(row.Task, today);
                    <div class="gantt-chart-row">
                        <div class="gantt-chart-label">
                            <span class="gantt-task-name" data-language-preserve translate="no">@row.Task.Name</span>
                            <small class="gantt-task-meta">負責人：@ownerName@if (!string.IsNullOrWhiteSpace(predecessorName)) { <text> · 前置工作：@predecessorName</text> }</small>
                            <div class="gantt-task-alerts">
                                <span class="gantt-task-state-badge @visualStateClass"><i></i>@visualStateLabel</span>
                                @if (overdue)
                                {
                                    <span class="gantt-overdue-badge">逾期</span>
                                }
                            </div>
                        </div>
                        <div class="gantt-chart-track">
                            @if (row.Task.IsMilestone && bar.WidthPercent >= 0)
                            {
                                <span class="gantt-task-milestone" style="left:@bar.LeftPercent.ToString("0.##")%;" title="里程碑：@row.Task.Name" aria-label="里程碑：@row.Task.Name"></span>
                            }
                            else if (bar.WidthPercent > 0)
                            {
                                <span class="gantt-bar @progressStageClass" style="left:@bar.LeftPercent.ToString("0.##")%;width:@bar.WidthPercent.ToString("0.##")%;" aria-label="@progressTooltip" title="@progressTooltip">
                                    <i style="width:@bar.ProgressPercent.ToString("0.##")%"></i>
                                </span>
                                <span class="gantt-bar-progress-label @progressStageClass" style="--gantt-progress-position:@progressPosition.ToString("0.##")%;">@progressText</span>
                            }
                        </div>
                        <div class="gantt-chart-percent @progressStageClass"><strong>@progressText</strong></div>
                    </div>
                }
                @if (taskRows.Count > 0)
                {
                    var previousX = archiveLinePosition;
                    decimal previousY = 0;
                    <div class="gantt-chart-overlay" aria-label="檔案日期進度折線">
                        <svg class="gantt-progress-line" viewBox="0 0 100 @taskRows.Count" preserveAspectRatio="none" aria-hidden="true">
                            @for (var pointIndex = 0; pointIndex < progressPoints.Count; pointIndex++)
                            {
                                var point = progressPoints[pointIndex];
                                var currentY = pointIndex + 0.5m;
                                var stateClass = point.State == GanttProgressState.Ahead ? "is-ahead" : point.State == GanttProgressState.Behind ? "is-behind" : "is-on-schedule";
                                <line class="@stateClass" x1="@previousX.ToString("0.###")" y1="@previousY.ToString("0.###")" x2="@point.PositionPercent.ToString("0.###")" y2="@currentY.ToString("0.###")" vector-effect="non-scaling-stroke" />
                                previousX = point.PositionPercent;
                                previousY = currentY;
                            }
                            <line class="is-on-schedule" x1="@previousX.ToString("0.###")" y1="@previousY.ToString("0.###")" x2="@archiveLinePosition.ToString("0.###")" y2="@taskRows.Count" vector-effect="non-scaling-stroke" />
                        </svg>
                        @for (var markerIndex = 0; markerIndex < progressPoints.Count; markerIndex++)
                        {
                            var markerPoint = progressPoints[markerIndex];
                            var markerTask = taskRows[markerIndex].Task;
                            var markerStateClass = markerPoint.State == GanttProgressState.Ahead ? "is-ahead" : markerPoint.State == GanttProgressState.Behind ? "is-behind" : "is-on-schedule";
                            var markerTooltip = $"{markerTask.Name}：{ProjectGanttService.GetProgressSummary(markerPoint)}";
                            var markerTop = (markerIndex + 0.5m) / taskRows.Count * 100m;
                            <span class="gantt-progress-marker @markerStateClass"
                                  style="left:@markerPoint.PositionPercent.ToString("0.###")%;top:@markerTop.ToString("0.###")%"
                                  tabindex="0"
                                  role="img"
                                  aria-label="@markerTooltip"
                                  data-tooltip="@markerTooltip"
                                  data-language-preserve
                                  translate="no"></span>
                        }
                    </div>
                }
            </div>
        </div>

        <div class="gantt-table-actions">
            <div class="chart-title">細分工作內容</div>
            @if (Model.CanEdit)
            {
                <button type="button" class="btn btn-outline-secondary btn-sm" data-gantt-add-row>新增一項</button>
            }
        </div>

        <div class="data-table-wrap">
            <table class="table table-sm align-middle data-table gantt-edit-table">
                <thead>
                    <tr>
                        <th>序號</th>
                        <th>細分工作內容</th>
                        <th>里程碑</th>
                        <th>負責人</th>
                        <th>前置工作</th>
                        <th>預計開始日</th>
                        <th>預計完成日</th>
                        <th>實際開始</th>
                        <th>實際完成</th>
                        <th>目前進度 %</th>
                        <th>進度說明</th>
                        <th>操作</th>
                    </tr>
                </thead>
                <tbody data-gantt-rows>
                @for (var i = 0; i < input.Tasks.Count; i++)
                {
                    <tr data-gantt-row>
                        <td class="numeric">
                            <input type="hidden" name="GanttInput.Tasks[@i].Id" value="@input.Tasks[i].Id" />
                            <input type="hidden" name="GanttInput.Tasks[@i].SortOrder" value="@(i + 1)" data-gantt-sort />
                            <span data-gantt-index>@(i + 1)</span>
                        </td>
                        <td><input class="form-control form-control-sm" name="GanttInput.Tasks[@i].Name" value="@input.Tasks[i].Name" @(Model.CanEdit ? null : "readonly") /></td>
                        <td class="text-center"><input class="form-check-input" name="GanttInput.Tasks[@i].IsMilestone" type="checkbox" value="true" @(input.Tasks[i].IsMilestone ? "checked" : null) @(Model.CanEdit ? null : "disabled") /><input type="hidden" name="GanttInput.Tasks[@i].IsMilestone" value="false" /></td>
                        <td>
                            <select class="form-select form-select-sm" name="GanttInput.Tasks[@i].OwnerUserId" @(Model.CanEdit ? null : "disabled")>
                                <option value="">未指派</option>
                                @foreach (var assignment in Model.Project.Assignments)
                                {
                                    var selected = assignment.UserId == input.Tasks[i].OwnerUserId;
                                    if (selected)
                                    {
                                        <option value="@assignment.UserId" selected>@(assignment.User?.DisplayName ?? assignment.User?.UserName ?? assignment.UserId)</option>
                                    }
                                    else
                                    {
                                        <option value="@assignment.UserId">@(assignment.User?.DisplayName ?? assignment.User?.UserName ?? assignment.UserId)</option>
                                    }
                                }
                            </select>
                        </td>
                        <td>
                            <select class="form-select form-select-sm" name="GanttInput.Tasks[@i].PredecessorTaskId" @(Model.CanEdit ? null : "disabled")>
                                <option value="">無</option>
                                @foreach (var candidate in input.Tasks.Where(task => task.Id > 0 && task.Id != input.Tasks[i].Id))
                                {
                                    var selected = candidate.Id == input.Tasks[i].PredecessorTaskId;
                                    if (selected)
                                    {
                                        <option value="@candidate.Id" selected>@candidate.Name</option>
                                    }
                                    else
                                    {
                                        <option value="@candidate.Id">@candidate.Name</option>
                                    }
                                }
                            </select>
                        </td>
                        <td><input class="form-control form-control-sm" name="GanttInput.Tasks[@i].PlannedStartDate" type="date" value="@input.Tasks[i].PlannedStartDate?.ToString("yyyy-MM-dd")" @(Model.CanEdit ? null : "readonly") /></td>
                        <td><input class="form-control form-control-sm" name="GanttInput.Tasks[@i].PlannedFinishDate" type="date" value="@input.Tasks[i].PlannedFinishDate?.ToString("yyyy-MM-dd")" @(Model.CanEdit ? null : "readonly") /></td>
                        <td><input class="form-control form-control-sm" name="GanttInput.Tasks[@i].ActualStartDate" type="date" value="@input.Tasks[i].ActualStartDate?.ToString("yyyy-MM-dd")" @(Model.CanEdit ? null : "readonly") /></td>
                        <td><input class="form-control form-control-sm" name="GanttInput.Tasks[@i].ActualFinishDate" type="date" value="@input.Tasks[i].ActualFinishDate?.ToString("yyyy-MM-dd")" @(Model.CanEdit ? null : "readonly") /></td>
                        <td><input class="form-control form-control-sm" name="GanttInput.Tasks[@i].ProgressPercent" value="@input.Tasks[i].ProgressPercent" @(Model.CanEdit ? null : "readonly") /></td>
                        <td><input class="form-control form-control-sm" name="GanttInput.Tasks[@i].ProgressDescription" value="@input.Tasks[i].ProgressDescription" @(Model.CanEdit ? null : "readonly") /></td>
                        <td>
                            @if (Model.CanEdit)
                            {
                                <button type="button" class="btn btn-outline-danger btn-sm" data-gantt-remove-row>刪除</button>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>

        @if (Model.CanEdit)
        {
            <div class="mt-3">
                <button type="submit" class="btn btn-primary">儲存甘特圖</button>
            </div>
        }
    </form>
</section>
