@model ProjectManager.Web.Models.Project
@using ProjectManager.Web.Models
@using ProjectManager.Web.Pages.Shared
@{
    var purchaseRequests = Model.PurchaseRequests.Where(x => !x.IsDeleted).ToList();
    var purchaseAmountTotal = purchaseRequests.Sum(x => x.PurchaseAmount);
    var actualPaidTotal = purchaseRequests.Sum(x => x.ActualPaidAmount);
    var paidPercent = purchaseAmountTotal <= 0 ? 0 : Math.Round(actualPaidTotal / purchaseAmountTotal * 100, 2);
    var internalCount = purchaseRequests.Count(x => x.PurchaseType == PurchaseType.InternalPurchase);
    var externalCount = purchaseRequests.Count(x => x.PurchaseType == PurchaseType.ExternalPurchase);
    var purchaseCoverage = Model.ProjectAmount <= 0 ? 0 : Math.Round(purchaseAmountTotal / Model.ProjectAmount * 100, 2);
}

<section class="project-visual-grid">
    <div class="project-visual-card project-visual-card-main">
        <div class="chart-card-header">
            <div>
                <div class="chart-title">專案推進概覽</div>
                <div class="chart-subtitle">進度、收款和請購付款的綜合狀態</div>
            </div>
            <partial name="_StatusBadge" model="Model.Status" />
        </div>
        <div class="detail-progress-stack">
            <div>
                <div class="detail-progress-label">專案進度</div>
                <partial name="_PercentBar" model="new PercentBarModel(Model.ProgressPercent, compact: false)" />
            </div>
            <div>
                <div class="detail-progress-label">收款比例</div>
                <partial name="_PercentBar" model="new PercentBarModel(Model.CollectionPercent, compact: false)" />
            </div>
            <div>
                <div class="detail-progress-label">請購付款</div>
                <partial name="_PercentBar" model="new PercentBarModel(paidPercent, compact: false)" />
            </div>
        </div>
    </div>

    <div class="project-visual-card">
        <div class="chart-title">金額結構</div>
        <div class="chart-subtitle">專案金額、請購金額和實際付款</div>
        <div class="detail-kpi-grid">
            <div class="detail-kpi">
                <span>專案金額</span>
                <strong>@Model.ProjectAmount.ToString("N2")</strong>
            </div>
            <div class="detail-kpi">
                <span>請購金額</span>
                <strong>@purchaseAmountTotal.ToString("N2")</strong>
            </div>
            <div class="detail-kpi">
                <span>實際已付款</span>
                <strong>@actualPaidTotal.ToString("N2")</strong>
            </div>
            <div class="detail-kpi">
                <span>請購覆蓋</span>
                <strong>@purchaseCoverage.ToString("0.##")%</strong>
            </div>
        </div>
    </div>

    <div class="project-visual-card">
        <div class="chart-title">請購結構</div>
        <div class="chart-subtitle">按內購與外購分類</div>
        <div class="purchase-type-bars">
            <div class="purchase-type-row" style="--bar-width:@(purchaseRequests.Count == 0 ? 0 : Math.Round(internalCount / (decimal)purchaseRequests.Count * 100, 1))%;--bar-color:#2563eb">
                <span>內購</span>
                <div class="bar-track"><i></i></div>
                <strong>@internalCount</strong>
            </div>
            <div class="purchase-type-row" style="--bar-width:@(purchaseRequests.Count == 0 ? 0 : Math.Round(externalCount / (decimal)purchaseRequests.Count * 100, 1))%;--bar-color:#14b8a6">
                <span>外購</span>
                <div class="bar-track"><i></i></div>
                <strong>@externalCount</strong>
            </div>
        </div>
    </div>
</section>
