@page
@model ProjectManager.Web.Pages.Reports.OpenProjects.StatisticsModel
@{
    ViewData["Title"] = "未結案統計";
}

<div class="page-header">
    <div>
        <h1 class="page-title">未結案統計</h1>
        <div class="page-subtitle">按狀態彙總專案數量、金額、请购和付款資料</div>
    </div>
    <div class="page-actions">
        <a class="btn btn-outline-secondary" asp-page="./Index">返回報表</a>
    </div>
</div>

<div class="data-table-wrap">
    <table class="table table-sm table-striped align-middle data-table">
        <thead>
            <tr>
                <th>狀態</th>
                <th class="numeric">專案数</th>
                <th class="numeric">專案金額合計</th>
                <th class="numeric">请购金額合計</th>
                <th class="numeric">實際已付款合計</th>
                <th class="numeric">平均收款比例</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var row in Model.Rows)
        {
            <tr>
                <td>@row.StatusName</td>
                <td class="numeric">@row.Count</td>
                <td class="numeric">@row.ProjectAmountTotal.ToString("N2")</td>
                <td class="numeric">@row.PurchaseAmountTotal.ToString("N2")</td>
                <td class="numeric">@row.ActualPaidAmountTotal.ToString("N2")</td>
                <td class="numeric"><partial name="_PercentBar" model="new ProjectManager.Web.Pages.Shared.PercentBarModel(row.AverageCollectionPercent)" /></td>
            </tr>
        }
        </tbody>
    </table>
</div>
