@model IReadOnlyList<ProjectManager.Web.Models.Project>
@using ProjectManager.Web.Models

<div class="data-table-wrap">
    <table class="table table-sm table-striped align-middle data-table">
        <thead>
            <tr>
                <th>年</th>
                <th>母案案號</th>
                <th>專案工號</th>
                <th>專案名稱</th>
                <th>專案人員</th>
                <th class="numeric">進度</th>
                <th class="numeric">專案金額</th>
                <th class="numeric">收款比例</th>
                <th>狀態</th>
                <th>推进判断</th>
                <th>結案日期</th>
                <th class="numeric">请购金額</th>
                <th>子案對接人員</th>
                <th class="numeric">實際已付款</th>
                <th>進度說明</th>
                <th>更新人员</th>
                <th>最后更新時間</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var project in Model)
        {
            var purchaseRequests = project.PurchaseRequests.Where(x => !x.IsDeleted).ToList();
            <tr>
                <td>@project.Year</td>
                <td>@project.ParentCaseNumber</td>
                <td>@project.ProjectNumber</td>
                <td>@project.Name</td>
                <td>@string.Join("；", project.Assignments.Select(x => x.User?.DisplayName ?? x.User?.UserName ?? x.UserId))</td>
                <td class="numeric"><partial name="_PercentBar" model="new ProjectManager.Web.Pages.Shared.PercentBarModel(project.ProgressPercent)" /></td>
                <td class="numeric">@project.ProjectAmount.ToString("N2")</td>
                <td class="numeric"><partial name="_PercentBar" model="new ProjectManager.Web.Pages.Shared.PercentBarModel(project.CollectionPercent)" /></td>
                <td><partial name="_StatusBadge" model="project.Status" /></td>
                <td><partial name="_ProgressRiskBadge" model="project" /></td>
                <td>@project.ClosedYearMonth?.ToString("yyyy-MM")</td>
                <td class="numeric">@purchaseRequests.Sum(x => x.PurchaseAmount).ToString("N2")</td>
                <td>@string.Join("；", purchaseRequests.Select(x => x.SubCaseContact?.DisplayName ?? x.SubCaseContact?.UserName).Where(x => !string.IsNullOrWhiteSpace(x)).Distinct())</td>
                <td class="numeric">@purchaseRequests.Sum(x => x.ActualPaidAmount).ToString("N2")</td>
                <td>@project.ProgressDescription</td>
                <td>@(project.UpdatedByUser?.DisplayName ?? project.UpdatedByUser?.UserName)</td>
                <td>@project.UpdatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
            </tr>
        }
        @if (!Model.Any())
        {
            <tr>
                <td colspan="17">
                    <div class="empty-state">暂无符合筆件的未結案專案</div>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
