@page
@model ProjectManager.Web.Pages.Reports.OpenProjects.PrintModel
@{
    ViewData["Title"] = "未結案專案列印";
    ViewData["VisibleColumns"] = new[]
    {
        "year",
        "parentCaseNumber",
        "assignments",
        "progress",
        "projectAmount",
        "collectionPercent",
        "status",
        "risk",
        "updatedAt"
    };
    ViewData["RowDensity"] = "Compact";
    Layout = "_PrintLayout";
}

<div class="print-report print-report-wide">
    <div class="d-flex align-items-center justify-content-between mb-3 no-print">
        <h1 class="h3 mb-0">未結案專案列印</h1>
        <button class="btn btn-primary" type="button" onclick="window.print()">列印</button>
    </div>

    <h1 class="h4">未結案專案報表</h1>
    <partial name="_OpenProjectsTable" model="Model.Projects" />
</div>
