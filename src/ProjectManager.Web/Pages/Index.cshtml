@page
@using ProjectManager.Web.Security
@model IndexModel
@{
    ViewData["Title"] = "首页";
}

<div class="dashboard-header">
    <div>
        <h1 class="h3 mb-1">项目管理系统</h1>
        <div class="text-muted">公司内网项目、请购、月结和未结案报表工作台</div>
    </div>
    <div class="dashboard-meta">
        <span>SQL Server</span>
        <span>ASP.NET Core</span>
    </div>
</div>

<div class="metric-grid mb-4">
    <div class="metric-tile">
        <div class="metric-label">项目总数</div>
        <div class="metric-value">@Model.TotalProjectCount</div>
    </div>
    <div class="metric-tile">
        <div class="metric-label">未结案项目</div>
        <div class="metric-value">@Model.OpenProjectCount</div>
    </div>
    <div class="metric-tile">
        <div class="metric-label">启用状态</div>
        <div class="metric-value">@Model.ActiveStatusCount</div>
    </div>
    <div class="metric-tile">
        <div class="metric-label">月结批次</div>
        <div class="metric-value">@Model.SettlementBatchCount</div>
    </div>
</div>

<div class="entrance-grid">
    @if (User.IsInRole(RoleNames.Administrator))
    {
        <section class="entrance-panel">
            <div class="entrance-title">后台管理入口</div>
            <div class="entrance-subtitle">维护用户、项目资料、请购记录和状态样式。</div>
            <div class="entrance-actions">
                <a class="btn btn-primary" asp-page="/Admin/Projects/Index">项目管理</a>
                <a class="btn btn-outline-secondary" asp-page="/Admin/Users/Index">用户管理</a>
                <a class="btn btn-outline-secondary" asp-page="/Admin/Statuses/Index">状态设置</a>
            </div>
        </section>
    }

    @if (User.IsInRole(RoleNames.Administrator) || User.IsInRole(RoleNames.ProjectStaff) || User.IsInRole(RoleNames.Leader) || User.IsInRole(RoleNames.Viewer))
    {
        <section class="entrance-panel">
            <div class="entrance-title">Web 工作台入口</div>
            <div class="entrance-subtitle">查看项目状态图、更新项目进度、跟踪请购和收款情况。</div>
            <div class="entrance-actions">
                <a class="btn btn-primary" asp-page="/Workbench/Projects/Index">我的项目</a>
                <a class="btn btn-outline-secondary" asp-page="/Reports/OpenProjects/Index">报表</a>
            </div>
        </section>
    }

    @if (User.IsInRole(RoleNames.Administrator) || User.IsInRole(RoleNames.Leader))
    {
        <section class="entrance-panel">
            <div class="entrance-title">月结与统计</div>
            <div class="entrance-subtitle">手动生成月度结算快照，导出 Excel，打印月结报表。</div>
            <div class="entrance-actions">
                <a class="btn btn-primary" asp-page="/Settlements/Create">生成月结</a>
                <a class="btn btn-outline-secondary" asp-page="/Settlements/Index">月结</a>
                <a class="btn btn-outline-secondary" asp-page="/Reports/OpenProjects/Statistics">统计</a>
            </div>
        </section>
    }

    @if (!User.Identity?.IsAuthenticated ?? true)
    {
        <section class="entrance-panel">
            <div class="entrance-title">请先登录</div>
            <div class="entrance-subtitle">登录后会根据角色显示对应的后台管理和 Web 工作台入口。</div>
            <div class="entrance-actions">
                <a class="btn btn-primary" asp-area="Identity" asp-page="/Account/Login">登录</a>
            </div>
        </section>
    }
</div>
