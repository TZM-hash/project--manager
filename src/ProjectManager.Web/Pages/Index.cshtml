@page
@using ProjectManager.Web.Security
@model IndexModel
@{
    ViewData["Title"] = "個人工作台";
}

@if (User.Identity?.IsAuthenticated == true && Model.Workbench is not null)
{
    <div class="workbench-heading">
        <div>
            <div class="eyebrow">今日工作焦點</div>
            <h1 class="page-title">個人工作台</h1>
            <p class="workbench-subtitle">集中查看需要立即處理的專案風險與近期節點。</p>
        </div>
        <span class="meta-pill">依目前帳號權限顯示</span>
    </div>

    <section class="workbench-hero workbench-hero-@Model.Workbench.HeroTone" aria-labelledby="workbench-conclusion">
        <div class="workbench-hero-content">
            <span class="workbench-hero-label">主結論</span>
            <h2 id="workbench-conclusion">@Model.Workbench.HeroTitle</h2>
            <p>@Model.Workbench.HeroDescription</p>
        </div>
        <a class="btn btn-primary workbench-primary-action" href="@Model.Workbench.PrimaryActionUrl">
            @Model.Workbench.PrimaryActionText
        </a>
    </section>

    <nav class="workbench-counters" aria-label="工作佇列摘要">
        <a href="/Workbench/Projects/Index?AnalysisType=overdue" class="workbench-counter workbench-counter-danger">
            <span>我的逾期</span>
            <strong>@Model.Workbench.OverdueCount</strong>
            <small>超過計畫完成日</small>
        </a>
        <a href="/Workbench/Projects/Index?AnalysisType=pending" class="workbench-counter workbench-counter-warning">
            <span>待處理</span>
            <strong>@Model.Workbench.PendingCount</strong>
            <small>等待、阻塞或收款落後</small>
        </a>
        <a href="/Workbench/Projects/Index?AnalysisType=upcoming" class="workbench-counter workbench-counter-info">
            <span>近期節點</span>
            <strong>@Model.Workbench.UpcomingNodeCount</strong>
            <small>未來 14 天到期</small>
        </a>
        <a href="/Workbench/Projects/Index?AnalysisType=stale-update" class="workbench-counter workbench-counter-neutral">
            <span>長期未更新</span>
            <strong>@Model.Workbench.StaleCount</strong>
            <small>超過 30 天未更新</small>
        </a>
    </nav>

    <div class="workbench-queue-grid">
        <section class="workbench-queue" aria-labelledby="overdue-title">
            <header>
                <div>
                    <span class="queue-kicker queue-kicker-danger">優先處理</span>
                    <h2 id="overdue-title">我的逾期</h2>
                </div>
                <a href="/Workbench/Projects/Index?AnalysisType=overdue">查看全部</a>
            </header>
            @if (Model.Workbench.OverdueProjects.Count == 0)
            {
                <div class="workbench-empty">
                    <strong>目前沒有逾期專案</strong>
                    <span>所有未結案專案都仍在計畫完成日前。</span>
                    <a asp-page="/Workbench/Projects/Index">查看我的專案</a>
                </div>
            }
            else
            {
                <div class="workbench-list">
                    @foreach (var item in Model.Workbench.OverdueProjects)
                    {
                        <a class="workbench-list-item" asp-page="/Workbench/Projects/Details" asp-route-id="@item.ProjectId">
                            <span><strong>@item.ProjectNumber</strong>@item.Name</span>
                            <small>@item.Reason · 進度 @item.ProgressPercent.ToString("0.#")%</small>
                        </a>
                    }
                </div>
            }
        </section>

        <section class="workbench-queue" aria-labelledby="pending-title">
            <header>
                <div>
                    <span class="queue-kicker queue-kicker-warning">需要確認</span>
                    <h2 id="pending-title">待處理</h2>
                </div>
                <a href="/Workbench/Projects/Index?AnalysisType=pending">查看全部</a>
            </header>
            @if (Model.Workbench.PendingProjects.Count == 0)
            {
                <div class="workbench-empty">
                    <strong>目前沒有待處理專案</strong>
                    <span>沒有等待、阻塞或收款進度明顯落後的專案。</span>
                    <a asp-page="/Workbench/Projects/Index">檢視專案狀態</a>
                </div>
            }
            else
            {
                <div class="workbench-list">
                    @foreach (var item in Model.Workbench.PendingProjects)
                    {
                        <a class="workbench-list-item" asp-page="/Workbench/Projects/Details" asp-route-id="@item.ProjectId">
                            <span><strong>@item.ProjectNumber</strong>@item.Name</span>
                            <small>@item.Reason · 收款 @item.CollectionPercent.ToString("0.#")%</small>
                        </a>
                    }
                </div>
            }
        </section>

        <section class="workbench-queue" aria-labelledby="upcoming-title">
            <header>
                <div>
                    <span class="queue-kicker queue-kicker-info">提前準備</span>
                    <h2 id="upcoming-title">近期節點</h2>
                </div>
                <a href="/Workbench/Projects/Index?AnalysisType=upcoming">查看全部</a>
            </header>
            @if (Model.Workbench.UpcomingNodes.Count == 0)
            {
                <div class="workbench-empty">
                    <strong>未來 14 天沒有到期節點</strong>
                    <span>目前沒有尚未完成且即將到期的甘特任務。</span>
                    <a asp-page="/Workbench/Projects/Index">查看甘特計畫</a>
                </div>
            }
            else
            {
                <div class="workbench-list">
                    @foreach (var item in Model.Workbench.UpcomingNodes)
                    {
                        <a class="workbench-list-item" asp-page="/Workbench/Projects/Details" asp-route-id="@item.ProjectId" asp-fragment="gantt">
                            <span><strong>@item.TaskName</strong>@item.ProjectNumber · @item.ProjectName</span>
                            <small>@item.PlannedFinishDate.ToString("yyyy/MM/dd") 到期 · 進度 @item.ProgressPercent.ToString("0.#")%</small>
                        </a>
                    }
                </div>
            }
        </section>

        <section class="workbench-queue" aria-labelledby="stale-title">
            <header>
                <div>
                    <span class="queue-kicker">補充現況</span>
                    <h2 id="stale-title">長期未更新</h2>
                </div>
                <a href="/Workbench/Projects/Index?AnalysisType=stale-update">查看全部</a>
            </header>
            @if (Model.Workbench.StaleProjects.Count == 0)
            {
                <div class="workbench-empty">
                    <strong>近期更新狀況良好</strong>
                    <span>所有未結案專案都在最近 30 天內更新過。</span>
                    <a asp-page="/Workbench/Projects/Index">維護專案進度</a>
                </div>
            }
            else
            {
                <div class="workbench-list">
                    @foreach (var item in Model.Workbench.StaleProjects)
                    {
                        <a class="workbench-list-item" asp-page="/Workbench/Projects/Details" asp-route-id="@item.ProjectId">
                            <span><strong>@item.ProjectNumber</strong>@item.Name</span>
                            <small>@item.Reason · @item.StatusName</small>
                        </a>
                    }
                </div>
            }
        </section>
    </div>

    <section class="workbench-shortcuts" aria-labelledby="shortcut-title">
        <div>
            <span class="eyebrow">常用入口</span>
            <h2 id="shortcut-title">快捷操作</h2>
        </div>
        <div class="workbench-shortcut-actions">
            <a class="btn btn-outline-primary" asp-page="/Workbench/Projects/Index">我的專案</a>
            <a class="btn btn-outline-secondary" asp-page="/Reports/OpenProjects/Index">未結案報表</a>
            @if (User.IsInRole(RoleNames.Administrator) || User.IsInRole(RoleNames.Leader))
            {
                <a class="btn btn-outline-secondary" asp-page="/Settlements/Create">生成月結</a>
            }
            @if (User.IsInRole(RoleNames.Administrator))
            {
                <a class="btn btn-outline-secondary" asp-page="/Admin/Projects/Index">專案管理</a>
            }
        </div>
    </section>
}
else
{
    <section class="workbench-login" aria-labelledby="login-title">
        <div>
            <div class="eyebrow">台塑電子專案管理系統</div>
            <h1 id="login-title" class="page-title">請先登入，開啟個人工作台</h1>
            <p>系統會依照角色顯示可處理的逾期專案、待辦事項、近期節點與常用入口。</p>
        </div>
        <a class="btn btn-primary" asp-area="Identity" asp-page="/Account/Login">登入</a>
    </section>
}
