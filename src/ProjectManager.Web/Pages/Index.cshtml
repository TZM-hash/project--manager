@page
@using ProjectManager.Web.Security
@model IndexModel
@{
    ViewData["Title"] = "首頁";
}

<div class="dashboard-header">
    <div>
        <h1 class="page-title">台塑電子專案管理系統</h1>
        <div class="dashboard-subtitle">集中管理公司內網專案、請購、月結和未結案報表</div>
    </div>
    <div class="dashboard-meta">
        <span>內網部署</span>
        <span>WEB 我的專案</span>
    </div>
</div>

<div class="metric-grid dashboard-grid">
    @foreach (var metric in Model.Metrics)
    {
        <div class="metric-card metric-@metric.Accent">
            <div class="metric-label">@metric.Label</div>
            <div class="metric-value" data-countup>@metric.Value</div>
            <div class="metric-hint">@metric.Hint</div>
        </div>
    }
</div>

<div class="dashboard-visual-grid">
    <section class="chart-card chart-card-feature">
        <div class="chart-card-header">
            <div>
                <div class="chart-title">未結案占比</div>
                <div class="chart-subtitle">整體專案推進壓力</div>
            </div>
            <span class="meta-pill">@Model.OpenProjectCount / @Model.TotalProjectCount</span>
        </div>
        <div class="donut-wrap">
            <div class="donut-chart" style="--donut-color:#2563eb;--donut-percent:@Model.OpenProjectPercent">
                <span>@Model.OpenProjectPercent.ToString("0.#")%</span>
            </div>
            <div class="legend-list">
                @foreach (var slice in Model.OpenClosedSlices)
                {
                    <div class="legend-item"><span style="background:@slice.Color"></span>@slice.Label @slice.Value.ToString("0")</div>
                }
            </div>
        </div>
    </section>

    <section class="chart-card">
        <div class="chart-title">專案狀態分布</div>
        <div class="chart-subtitle">按狀態彙總目前有效專案</div>
        <div class="bar-list">
            @foreach (var slice in Model.StatusSlices)
            {
                <div class="bar-row" style="--bar-width:@slice.Percent%;--bar-color:@slice.Color">
                    <div class="bar-row-label">@slice.Label</div>
                    <div class="bar-track"><span></span></div>
                    <div class="bar-value">@slice.Value.ToString("0")</div>
                </div>
            }
        </div>
    </section>

    <section class="chart-card">
        <div class="chart-title">月結批次趨勢</div>
        <div class="chart-subtitle">最近 6 个有批次月份</div>
        <div class="mini-bars">
            @foreach (var slice in Model.SettlementSlices)
            {
                <div class="mini-bar" style="--bar-height:@slice.Percent%;--bar-color:@slice.Color">
                    <span></span>
                    <strong>@slice.Value.ToString("0")</strong>
                    <small>@slice.Label</small>
                </div>
            }
        </div>
    </section>
</div>

<div class="module-grid">
    @if (User.IsInRole(RoleNames.Administrator))
    {
        <section class="module-card">
            <div class="module-title">後台管理入口</div>
            <div class="module-subtitle">維護使用者、專案資料、請購記錄和狀態樣式。</div>
            <div class="module-actions">
                <a class="btn btn-primary" asp-page="/Admin/Projects/Index">專案總覽</a>
                <a class="btn btn-outline-secondary" asp-page="/Admin/Users/Index">使用者管理</a>
                <a class="btn btn-outline-secondary" asp-page="/Admin/Statuses/Index">狀態設定</a>
            </div>
        </section>
    }

    @if (User.IsInRole(RoleNames.Administrator) || User.IsInRole(RoleNames.ProjectStaff) || User.IsInRole(RoleNames.Leader) || User.IsInRole(RoleNames.Viewer))
    {
        <section class="module-card">
            <div class="module-title">WEB 我的專案入口</div>
            <div class="module-subtitle">查看專案狀態圖、更新專案進度、跟蹤請購和收款情況。</div>
            <div class="module-actions">
                <a class="btn btn-primary" asp-page="/Workbench/Projects/Index">我的專案</a>
                <a class="btn btn-outline-secondary" asp-page="/Reports/OpenProjects/Index">報表</a>
            </div>
        </section>
    }

    @if (User.IsInRole(RoleNames.Administrator) || User.IsInRole(RoleNames.Leader))
    {
        <section class="module-card">
            <div class="module-title">月結與統計</div>
            <div class="module-subtitle">手動生成月度結算快照，匯出 Excel，列印月結報表。</div>
            <div class="module-actions">
                <a class="btn btn-primary" asp-page="/Settlements/Create">生成月結</a>
                <a class="btn btn-outline-secondary" asp-page="/Settlements/Index">月結</a>
                <a class="btn btn-outline-secondary" asp-page="/Reports/OpenProjects/Statistics">統計</a>
            </div>
        </section>
    }

    @if (!User.Identity?.IsAuthenticated ?? true)
    {
        <section class="module-card">
            <div class="module-title">請先登入</div>
            <div class="module-subtitle">登入後會根據角色顯示對應的後台管理和 WEB 我的專案入口。</div>
            <div class="module-actions">
                <a class="btn btn-primary" asp-area="Identity" asp-page="/Account/Login">登入</a>
            </div>
        </section>
    }
</div>
