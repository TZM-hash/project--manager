@page "{id:int}"
@model ProjectManager.Web.Pages.Workbench.PlanningProjects.PrintModel
@{
    ViewData["Title"] = "規劃中專案報表";
    Layout = "_PrintLayout";
}

<style>
    @@page {
        size: A4 landscape;
        margin: 10mm;
    }
</style>

<div class="print-report planning-print-report" id="printContent">
    <header class="planning-print-header">
        <div>
            <div class="planning-print-eyebrow">PLANNING PROJECT</div>
            <h1>規劃中專案明細</h1>
            <p>專案意向、暫定合作資訊與月度推進記錄</p>
        </div>
        <div class="planning-print-date-card">
            <span>列印日期</span>
            <strong>@DateTime.Now.ToString("yyyy-MM-dd")</strong>
        </div>
    </header>

    <section class="planning-print-summary" aria-label="規劃專案摘要">
        <article class="planning-print-summary-item planning-print-summary-primary">
            <span>專案名稱</span>
            <strong>@Model.Project.Name</strong>
        </article>
        <article class="planning-print-summary-item">
            <span>暫定負責人</span>
            <strong>@Model.LeaderDisplayNames</strong>
        </article>
        <article class="planning-print-summary-item">
            <span>暫定廠商</span>
            <strong>@(Model.Project.Vendor ?? "-")</strong>
        </article>
        <article class="planning-print-summary-item">
            <span>建立時間</span>
            <strong>@Model.Project.CreatedAt.ToString("yyyy-MM-dd HH:mm")</strong>
        </article>
        <article class="planning-print-summary-item">
            <span>最近更新</span>
            <strong>@Model.Project.UpdatedAt.ToString("yyyy-MM-dd HH:mm")</strong>
        </article>
        <article class="planning-print-summary-item">
            <span>歷史記錄</span>
            <strong>@Model.Project.HistoryRecords.Count 筆</strong>
        </article>
    </section>

    @if (Model.Project.HistoryRecords.Count > 0)
    {
        <section class="planning-print-history">
            <div class="planning-print-section-heading">
                <div>
                    <span>MONTHLY LOG</span>
                    <h2>歷史記錄</h2>
                </div>
                <strong>@Model.Project.HistoryRecords.Count 筆</strong>
            </div>
            <table class="print-table print-table-list planning-print-history-table">
                <thead>
                    <tr>
                        <th>年月</th>
                        <th>本期記錄</th>
                        <th>記錄人</th>
                        <th>記錄時間</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var record in Model.Project.HistoryRecords)
                    {
                        <tr>
                            <td class="text-nowrap">@record.Year-@record.Month.ToString("00")</td>
                            <td class="rich-text-content">@Html.Raw(RichTextSanitizer.Normalize(record.CurrentRecord) ?? "-")</td>
                            <td>@(record.CreatedByUser?.DisplayName ?? record.CreatedByUser?.UserName ?? record.CreatedByUserId)</td>
                            <td>@record.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </section>
    }

    <footer class="planning-print-footer">
        <span>台塑電子專案管理系統</span>
        <span>規劃中專案資料僅供內部追蹤使用</span>
    </footer>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/opencc-js@1.0.5/dist/umd/full.min.js"></script>
    <script>
        window.onload = function() {
            // 繁體模式下將資料中的簡體中文轉為繁體；簡體模式保留全站轉換結果。
            if (document.body.classList.contains('lang-traditional') && typeof OpenCC !== 'undefined') {
                var converter = OpenCC.Converter({ from: 'cn', to: 'tw' });
                var content = document.getElementById('printContent');
                var walker = document.createTreeWalker(content, NodeFilter.SHOW_TEXT);
                var textNodes = [];
                while (walker.nextNode()) {
                    textNodes.push(walker.currentNode);
                }
                textNodes.forEach(function(node) {
                    node.nodeValue = converter(node.nodeValue);
                });
                document.title = converter(document.title);
            }
            var previewMode = new URLSearchParams(window.location.search).has('preview');
            if (!previewMode) {
                setTimeout(function() { window.print(); }, 300);
            }
        };
    </script>
}
