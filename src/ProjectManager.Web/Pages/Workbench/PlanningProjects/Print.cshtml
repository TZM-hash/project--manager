@page "{id:int}"
@model ProjectManager.Web.Pages.Workbench.PlanningProjects.PrintModel
@{
    ViewData["Title"] = "規劃中專案報表";
    Layout = "_PrintLayout";
}

<div class="print-report" id="printContent">
    <div class="print-header">
        <h1>規劃中專案報表</h1>
        <div class="print-date">列印日期：@DateTime.Now.ToString("yyyy-MM-dd")</div>
    </div>

    <table class="print-table">
        <tbody>
            <tr>
                <th>專案名</th>
                <td>@Model.Project.Name</td>
            </tr>
            <tr>
                <th>專案負責人</th>
                <td>@Model.LeaderDisplayNames</td>
            </tr>
            <tr>
                <th>廠商</th>
                <td>@(Model.Project.Vendor ?? "-")</td>
            </tr>
            <tr>
                <th>最新說明</th>
                <td class="rich-text-content">@Html.Raw(RichTextSanitizer.Normalize(Model.Project.LatestDescription) ?? "-")</td>
            </tr>
            <tr>
                <th>最近更新</th>
                <td>@Model.Project.UpdatedAt.ToString("yyyy-MM-dd HH:mm")</td>
            </tr>
        </tbody>
    </table>

    @if (Model.Project.HistoryRecords.Count > 0)
    {
        <h2 class="print-section-title">歷史記錄</h2>
        <table class="print-table print-table-list">
            <thead>
                <tr>
                    <th>年月</th>
                    <th>上期說明</th>
                    <th>本期記錄</th>
                    <th>記錄人</th>
                    <th>記錄時間</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var record in Model.Project.HistoryRecords)
                {
                    <tr>
                        <td>@record.Year-@record.Month.ToString("00")</td>
                        <td class="rich-text-content">@Html.Raw(RichTextSanitizer.Normalize(record.PreviousDescription) ?? "-")</td>
                        <td class="rich-text-content">@Html.Raw(RichTextSanitizer.Normalize(record.CurrentRecord) ?? "-")</td>
                        <td>@(record.CreatedByUser?.DisplayName ?? record.CreatedByUser?.UserName ?? record.CreatedByUserId)</td>
                        <td>@record.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/opencc-js@1.0.5/dist/umd/full.min.js"></script>
    <script>
        window.onload = function() {
            // 将所有中文简体转换为繁体
            if (typeof OpenCC !== 'undefined') {
                var converter = OpenCC.Converter({ from: 'cn', to: 'tw' });
                var content = document.getElementById('printContent');
                converter.convertElement(content);
                document.title = converter.convert(document.title);
            }
            // 转换完成后自动列印
            setTimeout(function() { window.print(); }, 300);
        };
    </script>
}
