@page
@model ProjectManager.Web.Pages.Workbench.PlanningProjects.PrintListModel
@{
    ViewData["Title"] = "規劃中專案清单";
    Layout = "_PrintLayout";
}

<div class="print-report print-report-wide planning-print-report planning-print-report-wide" id="printContent">
    <header class="planning-print-header">
        <div>
            <div class="planning-print-eyebrow">PLANNING PROJECT LIST</div>
            <h1>規劃中專案清單</h1>
            <p>彙整暫定負責人、暫定廠商與最新推進資訊</p>
        </div>
        <div class="planning-print-date-card">
            <span>列印日期</span>
            <strong>@DateTime.Now.ToString("yyyy-MM-dd")</strong>
        </div>
    </header>

    <div class="planning-print-list-summary">
        <span>本次列印</span>
        <strong>@Model.Projects.Count</strong>
        <span>筆規劃中專案</span>
    </div>

    <div class="planning-print-list-wrap">
    <table class="print-table print-table-list planning-print-list-table">
        <thead>
            <tr>
                <th class="planning-print-col-index">項次</th>
                <th class="planning-print-col-name">專案名稱</th>
                <th class="planning-print-col-leader">暫定負責人</th>
                <th class="planning-print-col-vendor">暫定廠商</th>
                <th>進度說明</th>
                <th class="planning-print-col-period">最新記錄年月</th>
                <th class="planning-print-col-updated">最近更新</th>
            </tr>
        </thead>
        <tbody>
            @{ var idx = 1; }
            @foreach (var project in Model.Projects)
            {
                <tr>
                    <td class="planning-print-index">@idx</td>
                    <td><strong>@project.Name</strong></td>
                    <td>@Model.GetLeaderDisplayNames(project.LeaderUserId)</td>
                    <td>@(project.Vendor ?? "-")</td>
                    <td class="rich-text-content">@Html.Raw(RichTextSanitizer.Normalize(project.LatestDescription) ?? "-")</td>
                    <td class="text-nowrap">@Model.GetLatestRecordPeriod(project)</td>
                    <td class="text-nowrap">@project.UpdatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                </tr>
                idx++;
            }
        </tbody>
    </table>
    </div>

    <footer class="planning-print-footer">
        <span>台塑電子專案管理系統</span>
        <span>共 @Model.Projects.Count 筆專案</span>
    </footer>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/opencc-js@1.0.5/dist/umd/full.min.js"></script>
    <script>
        window.onload = function() {
            if (document.body.classList.contains('lang-traditional') && typeof OpenCC !== 'undefined') {
                var converter = OpenCC.Converter({ from: 'cn', to: 'tw' });
                var content = document.getElementById('printContent');
                converter.convertElement(content);
                document.title = converter.convert(document.title);
            }
            var previewMode = new URLSearchParams(window.location.search).has('preview');
            if (!previewMode) {
                setTimeout(function() { window.print(); }, 300);
            }
        };
    </script>
}
